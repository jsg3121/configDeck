{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git tag:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Read",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npx prettier --write \"src/**/*.{ts,tsx,js,mjs,cjs,json,astro,svelte,css,html}\" 2>&1 | tail -3",
            "timeout": 30,
            "statusMessage": "Prettier 자동 포맷팅 중..."
          },
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npx eslint . --max-warnings 0 2>&1 | tail -5",
            "timeout": 60,
            "statusMessage": "ESLint 검증 중..."
          },
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && pnpm build 2>&1 | tail -5",
            "timeout": 120,
            "statusMessage": "Astro 빌드 검증 중..."
          }
        ]
      }
    ]
  },
  "language": "korean"
}
