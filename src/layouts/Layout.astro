---
import '@/styles/global.css'

import {
  buildLocalizedPath,
  DEFAULT_LOCALE,
  getAllLocaleAlternates,
  SUPPORTED_LOCALES,
  type Locale,
} from '@/i18n'

import AdvisoryAnnouncementBanner from '@/components/advisory/AdvisoryAnnouncementBanner.astro'
import Analytics from '@/components/common/Analytics.astro'
import Footer from '@/components/common/Footer.astro'
import Header from '@/components/common/Header.astro'

interface Props {
  title: string
  description?: string
  locale?: Locale
  /** Header/FooterÙÑ╝ ÝÅ¼Ýò¿ÝòÿýºÇ ýòèÙèö ýáäý▓┤ ý╗ñýèñÝàÇ ÙáêýØ┤ýòäýøâ (ýâØýä▒Û©░ 2ÙÂäÝòá Ùô▒) */
  bare?: boolean
  /** hreflang ýâØýä▒ýùÉ ýé¼ýÜ®Ýòá locale ýá£ýÖ© Û▓¢Ùí£ (ýÿê: "/generator") */
  pagePath?: string
  /** Ýÿäý×¼ ÝÖ£ýä▒ ÙäñÙ╣äÛ▓îýØ┤ýàÿ Û▓¢Ùí£ (ýÿê: "/generator") */
  currentPath?: string
  /** OG ýØ┤Ù»©ýºÇ URL */
  ogImage?: string
  /** canonical URLýØä Ù¬àýï£ýáüý£╝Ùí£ Ùì«ýû┤ýô┤Ùïñ.
   *  superseded advisoryý▓ÿÙƒ╝ Ýøäýåì ÝÄÿýØ┤ýºÇÙí£ canonicalýØä Û░ÇÙª¼ý╝£ýò╝ Ýòá Ùòî ýé¼ýÜ®Ýò£Ùïñ (SPEC-0006-design ┬º11-7).
   *  ýºÇýáòÝòÿýºÇ ýòèý£╝Ù®┤ locale + pagePathÙí£ ý×ÉÙÅÖ Û│äýé░ÙÉ£Ùïñ. */
  canonicalUrl?: string
  /** Û▓Çýâëýùöýºä ýâëýØ© Ù░®ýºÇ */
  noindex?: boolean
  /** JSON-LD ÛÁ¼ýí░ÝÖö Ùì░ýØ┤Ýä░ Ù░░ýù┤ */
  jsonLd?: Record<string, unknown>[]
  /** og:type ýÿñÙ▓äÙØ╝ýØ┤Ùô£ (Û©░Ù│©: website) */
  ogType?: 'website' | 'article'
  /** ýòäÝï░Ýü┤ Ù░£ÝûëýØ╝ (og:typeýØ┤ articleýØ╝ Ùòî ýé¼ýÜ®) */
  articlePublishedTime?: Date
  /** ýòäÝï░Ýü┤ ýêÿýáòýØ╝ (SPEC-0007 ┬º3.2.7). Ù»©ýºÇýáò ýï£ publishedýÖÇ ÙÅÖýØ╝ ý▓ÿÙª¼ ÛÂîý×Ñ. */
  articleModifiedTime?: Date
  /** ýòäÝï░Ýü┤ ýä╣ýàÿ/ý╣┤ÝàîÛ│áÙª¼ ÔÇö GoogleýØ┤ topic clusteringýùÉ ýé¼ýÜ®. ýÿê: "TypeScript" */
  articleSection?: string
  /** ýòäÝï░Ýü┤ Ýâ£ÛÀ© (Ùïñýñæ) ÔÇö GoogleýØ┤ topic ÙºñÝòæýùÉ ýé¼ýÜ®. */
  articleTag?: readonly string[]
}

const {
  title,
  description = 'Build project config files with stack-based presets',
  locale = DEFAULT_LOCALE,
  bare = false,
  pagePath = '/',
  currentPath,
  ogImage,
  canonicalUrl: canonicalUrlOverride,
  noindex = false,
  jsonLd = [],
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  articleTag,
} = Astro.props

const siteUrl = Astro.site ?? new URL('https://configdeck.dev')
// build.format: 'file' ÝÖÿÛ▓¢ýùÉýä£Ùèö Astro.url.pathnameýØ┤ ".html"ýØä ÝÅ¼Ýò¿ÝòÿÙ»ÇÙí£,
// pagePathýÖÇ localeÙí£ ýºüýáæ ýáòÛÀ£ÝÖöÙÉ£ Û▓¢Ùí£ÙÑ╝ ÙºîÙôáÙïñ (trailingSlash: 'never' ýáòý▒à ýØ╝ý╣ÿ).
// canonicalUrlOverrideÛ░Ç ýá£Û│ÁÙÉÿÙ®┤ Ù¬àýï£Û░ÆýØä ýÜ░ýäáÝò£Ùïñ (superseded advisoryýØÿ Ýøäýåì ÝÄÿýØ┤ýºÇ Û░ÇÙª¼ÝéñÛ©░ Ùô▒).
const canonicalUrl = canonicalUrlOverride
  ? new URL(canonicalUrlOverride, siteUrl)
  : new URL(buildLocalizedPath(locale, pagePath), siteUrl)
const localeAlternates = getAllLocaleAlternates(pagePath)
const ogLocaleMap: Record<Locale, string> = { en: 'en_US', ko: 'ko_KR' }
const defaultOgImage = new URL('/og-image.png', siteUrl).href
const ogImageUrl = ogImage ?? defaultOgImage
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Û©░Ù│© -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- hreflang (ýáêÙîÇ URL) -->
    {
      localeAlternates.map(({ locale: altLocale, href }) => (
        <link rel="alternate" hreflang={altLocale} href={new URL(href, siteUrl).href} />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(localeAlternates[0].href, siteUrl).href}
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    {
      ogType === 'article' && articlePublishedTime && (
        <meta property="article:published_time" content={articlePublishedTime.toISOString()} />
      )
    }
    {
      ogType === 'article' && articleModifiedTime && (
        <meta property="article:modified_time" content={articleModifiedTime.toISOString()} />
      )
    }
    {
      ogType === 'article' && articleSection && (
        <meta property="article:section" content={articleSection} />
      )
    }
    {
      ogType === 'article' &&
        articleTag &&
        articleTag.map((tag) => <meta property="article:tag" content={tag} />)
    }
    {
      SUPPORTED_LOCALES.filter((l) => l !== locale).map((altLocale) => (
        <meta property="og:locale:alternate" content={ogLocaleMap[altLocale]} />
      ))
    }
    <meta property="og:site_name" content="ConfigDeck" />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD ÛÁ¼ýí░ÝÖö Ùì░ýØ┤Ýä░ -->
    <!-- ýé¼ýØ┤Ýè© Û│ÁÝåÁ Organization (E-E-A-T ýÂ£ý▓ÿ ýïáÙó░ÙÅä ýïáÝÿ©) -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'ConfigDeck',
        url: siteUrl.href,
        logo: new URL('/favicon.svg', siteUrl).href,
      })}
    />
    {
      jsonLd.map((data) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify({ '@context': 'https://schema.org', ...data })}
        />
      ))
    }

    <!-- Google Analytics 4 (PUBLIC_GA_MEASUREMENT_ID ÝÖÿÛ▓¢Ù│ÇýêÿÛ░Ç ý×êýØä ÙòîÙºî ÝÖ£ýä▒ÝÖö) -->
    <Analytics />
  </head>
  <body class="flex min-h-screen flex-col bg-surface-alt font-sans text-gray-900">
    {!bare && <Header locale={locale} currentPath={currentPath ?? pagePath} />}
    {
      /*
       * Advisory Û│ÁýºÇ Ù░░Ùäê ÔÇö ÝùñÙìö Ù░öÙí£ ýòäÙ×ÿ.
       * advisory Ù│©ýØ© ÝÄÿýØ┤ýºÇ(/advisory, /advisory/{slug})ýùÉýä£Ùèö Ùà©ýÂ£ÝòÿýºÇ ýòèÙèöÙïñ (ýé¼ýÜ®ý×ÉýùÉÛ▓î ýñæÙ│Á+Ùà©ýØ┤ýªê).
       * bare ÙáêýØ┤ýòäýøâ(ýâØýä▒Û©░ 2ÙÂäÝòá Ùô▒)ýùÉýä£ÙÅä Ùà©ýÂ£ÝòÿýºÇ ýòèÙèöÙïñ.
       */
      !bare && !(currentPath ?? pagePath).startsWith('/advisory') && (
        <AdvisoryAnnouncementBanner locale={locale} />
      )
    }
    {
      bare ? (
        <slot />
      ) : (
        <main class="flex-1">
          <slot />
        </main>
      )
    }
    {!bare && <Footer />}
  </body>
</html>
