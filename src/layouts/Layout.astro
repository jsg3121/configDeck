---
import '@/styles/global.css'

import {
  buildLocalizedPath,
  DEFAULT_LOCALE,
  getAllLocaleAlternates,
  SUPPORTED_LOCALES,
  type Locale,
} from '@/i18n'

import AdvisoryAnnouncementBanner from '@/components/advisory/AdvisoryAnnouncementBanner.astro'
import Analytics from '@/components/common/Analytics.astro'
import Footer from '@/components/common/Footer.astro'
import Header from '@/components/common/Header.astro'

interface Props {
  title: string
  description?: string
  locale?: Locale
  /** Header/Footer를 포함하지 않는 전체 커스텀 레이아웃 (생성기 2분할 등) */
  bare?: boolean
  /** hreflang 생성에 사용할 locale 제외 경로 (예: "/generator") */
  pagePath?: string
  /**
   * hreflang 출력을 제어할 alternate 목록. 미지정 시 모든 SUPPORTED_LOCALES를 출력한다.
   * 일부 locale에만 콘텐츠가 존재하는 페이지(예: article 상세에서 한쪽 locale만 발행된 글)는
   * 실제 존재하는 locale 배열을 전달해 404 URL을 가리키는 hreflang을 막는다.
   */
  hreflangAlternates?: ReadonlyArray<{ locale: Locale; href: string }>
  /** 현재 활성 네비게이션 경로 (예: "/generator") */
  currentPath?: string
  /** OG 이미지 URL */
  ogImage?: string
  /** canonical URL을 명시적으로 덮어쓴다.
   *  superseded advisory처럼 후속 페이지로 canonical을 가리켜야 할 때 사용한다 (SPEC-0006-design §11-7).
   *  지정하지 않으면 locale + pagePath로 자동 계산된다. */
  canonicalUrl?: string
  /** 검색엔진 색인 방지 */
  noindex?: boolean
  /** JSON-LD 구조화 데이터 배열 */
  jsonLd?: Record<string, unknown>[]
  /** og:type 오버라이드 (기본: website) */
  ogType?: 'website' | 'article'
  /** 아티클 발행일 (og:type이 article일 때 사용) */
  articlePublishedTime?: Date
  /**
   * 아티클 수정일 (SPEC-0007 §3.2.7).
   * 미지정 시 Layout 내부에서 articlePublishedTime을 자동 fallback으로 사용한다.
   * 호출부가 동일 값을 중복 전달할 필요가 없도록 단일 책임을 Layout에 둔다.
   */
  articleModifiedTime?: Date
  /** 아티클 섹션/카테고리 — Google이 topic clustering에 사용. 예: "TypeScript" */
  articleSection?: string
  /** 아티클 태그 (다중) — Google이 topic 매핑에 사용. */
  articleTag?: readonly string[]
}

const {
  title,
  description = 'Build project config files with stack-based presets',
  locale = DEFAULT_LOCALE,
  bare = false,
  pagePath = '/',
  hreflangAlternates,
  currentPath,
  ogImage,
  canonicalUrl: canonicalUrlOverride,
  noindex = false,
  jsonLd = [],
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  articleTag,
} = Astro.props

const siteUrl = Astro.site ?? new URL('https://configdeck.dev')
// build.format: 'file' 환경에서는 Astro.url.pathname이 ".html"을 포함하므로,
// pagePath와 locale로 직접 정규화된 경로를 만든다 (trailingSlash: 'never' 정책 일치).
// canonicalUrlOverride가 제공되면 명시값을 우선한다 (superseded advisory의 후속 페이지 가리키기 등).
const canonicalUrl = canonicalUrlOverride
  ? new URL(canonicalUrlOverride, siteUrl)
  : new URL(buildLocalizedPath(locale, pagePath), siteUrl)
// `x-default`는 localeAlternates[0]을 참조하므로(아래 <link rel="alternate" hreflang="x-default">),
// 호출부 props 순서나 content collection 순회 순서에 의존하지 않도록 DEFAULT_LOCALE을 항상 선두로 둔다.
// Google 가이드: x-default는 "사이트의 기본/대표 언어 URL"을 가리켜야 한다.
const localeAlternates = [...(hreflangAlternates ?? getAllLocaleAlternates(pagePath))].sort(
  (a, b) => (a.locale === DEFAULT_LOCALE ? -1 : b.locale === DEFAULT_LOCALE ? 1 : 0),
)
const ogLocaleMap: Record<Locale, string> = { en: 'en_US', ko: 'ko_KR' }
const defaultOgImage = new URL('/og-image.png', siteUrl).href
const ogImageUrl = ogImage ?? defaultOgImage
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO 기본 -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- hreflang (절대 URL) -->
    {
      localeAlternates.map(({ locale: altLocale, href }) => (
        <link rel="alternate" hreflang={altLocale} href={new URL(href, siteUrl).href} />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(localeAlternates[0].href, siteUrl).href}
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    {
      ogType === 'article' && articlePublishedTime && (
        <meta property="article:published_time" content={articlePublishedTime.toISOString()} />
      )
    }
    {
      // articleModifiedTime이 명시되지 않았으면 published를 fallback으로 사용한다.
      // 호출부 중복 제거 + 모든 article 페이지의 일관된 메타데이터 출력 보장.
      ogType === 'article' && (articleModifiedTime || articlePublishedTime) && (
        <meta
          property="article:modified_time"
          content={(articleModifiedTime ?? articlePublishedTime)!.toISOString()}
        />
      )
    }
    {
      ogType === 'article' && articleSection && (
        <meta property="article:section" content={articleSection} />
      )
    }
    {
      ogType === 'article' &&
        articleTag &&
        articleTag.map((tag) => <meta property="article:tag" content={tag} />)
    }
    {
      SUPPORTED_LOCALES.filter((l) => l !== locale).map((altLocale) => (
        <meta property="og:locale:alternate" content={ogLocaleMap[altLocale]} />
      ))
    }
    <meta property="og:site_name" content="ConfigDeck" />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD 구조화 데이터 -->
    <!-- 사이트 공통 Organization (E-E-A-T 출처 신뢰도 신호) -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'ConfigDeck',
        url: siteUrl.href,
        logo: new URL('/favicon.svg', siteUrl).href,
      })}
    />
    {
      jsonLd.map((data) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify({ '@context': 'https://schema.org', ...data })}
        />
      ))
    }

    <!-- Google Analytics 4 (PUBLIC_GA_MEASUREMENT_ID 환경변수가 있을 때만 활성화) -->
    <Analytics />
  </head>
  <body class="flex min-h-screen flex-col bg-surface-alt font-sans text-gray-900">
    {!bare && <Header locale={locale} currentPath={currentPath ?? pagePath} />}
    {
      /*
       * Advisory 공지 배너 — 헤더 바로 아래.
       * advisory 본인 페이지(/advisory, /advisory/{slug})에서는 노출하지 않는다 (사용자에게 중복+노이즈).
       * bare 레이아웃(생성기 2분할 등)에서도 노출하지 않는다.
       */
      !bare && !(currentPath ?? pagePath).startsWith('/advisory') && (
        <AdvisoryAnnouncementBanner locale={locale} />
      )
    }
    {
      bare ? (
        <slot />
      ) : (
        <main class="flex-1">
          <slot />
        </main>
      )
    }
    {!bare && <Footer />}
  </body>
</html>
