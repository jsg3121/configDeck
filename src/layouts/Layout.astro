---
import '@/styles/global.css'

import {
  buildLocalizedPath,
  DEFAULT_LOCALE,
  getAllLocaleAlternates,
  SUPPORTED_LOCALES,
  type Locale,
} from '@/i18n'

import Footer from '@/components/common/Footer.astro'
import Header from '@/components/common/Header.astro'

interface Props {
  title: string
  description?: string
  locale?: Locale
  /** Header/FooterлҘј нҸ¬н•Ён•ҳм§Җ м•ҠлҠ” м „мІҙ м»ӨмҠӨн…Җ л Ҳмқҙм•„мӣғ (мғқм„ұкё° 2л¶„н•  л“ұ) */
  bare?: boolean
  /** hreflang мғқм„ұм—җ мӮ¬мҡ©н•  locale м ңмҷё кІҪлЎң (мҳҲ: "/generator") */
  pagePath?: string
  /** нҳ„мһ¬ нҷңм„ұ л„Өл№„кІҢмқҙм…ҳ кІҪлЎң (мҳҲ: "/generator") */
  currentPath?: string
  /** OG мқҙлҜём§Җ URL */
  ogImage?: string
  /** кІҖмғүм—”м§„ мғүмқё л°©м§Җ */
  noindex?: boolean
  /** JSON-LD кө¬мЎ°нҷ” лҚ°мқҙн„° л°°м—ҙ */
  jsonLd?: Record<string, unknown>[]
  /** og:type мҳӨлІ„лқјмқҙл“ң (кё°ліё: website) */
  ogType?: 'website' | 'article'
  /** м•„нӢ°нҒҙ л°ңн–үмқј (og:typeмқҙ articleмқј л•Ң мӮ¬мҡ©) */
  articlePublishedTime?: Date
}

const {
  title,
  description = 'Build project config files with stack-based presets',
  locale = DEFAULT_LOCALE,
  bare = false,
  pagePath = '/',
  currentPath,
  ogImage,
  noindex = false,
  jsonLd = [],
  ogType = 'website',
  articlePublishedTime,
} = Astro.props

const siteUrl = Astro.site ?? new URL('https://configdeck.dev')
// build.format: 'file' нҷҳкІҪм—җм„ңлҠ” Astro.url.pathnameмқҙ ".html"мқ„ нҸ¬н•Ён•ҳлҜҖлЎң,
// pagePathмҷҖ localeлЎң м§Ғм ‘ м •к·ңнҷ”лҗң кІҪлЎңлҘј л§Ңл“ лӢӨ (trailingSlash: 'never' м •мұ… мқјм№ҳ).
const canonicalUrl = new URL(buildLocalizedPath(locale, pagePath), siteUrl)
const localeAlternates = getAllLocaleAlternates(pagePath)
const ogLocaleMap: Record<Locale, string> = { en: 'en_US', ko: 'ko_KR' }
const defaultOgImage = new URL('/og-image.png', siteUrl).href
const ogImageUrl = ogImage ?? defaultOgImage
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO кё°ліё -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- hreflang (м ҲлҢҖ URL) -->
    {
      localeAlternates.map(({ locale: altLocale, href }) => (
        <link rel="alternate" hreflang={altLocale} href={new URL(href, siteUrl).href} />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(localeAlternates[0].href, siteUrl).href}
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    {
      ogType === 'article' && articlePublishedTime && (
        <meta property="article:published_time" content={articlePublishedTime.toISOString()} />
      )
    }
    {
      SUPPORTED_LOCALES.filter((l) => l !== locale).map((altLocale) => (
        <meta property="og:locale:alternate" content={ogLocaleMap[altLocale]} />
      ))
    }
    <meta property="og:site_name" content="ConfigDeck" />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD кө¬мЎ°нҷ” лҚ°мқҙн„° -->
    <!-- мӮ¬мқҙнҠё кіөнҶө Organization (E-E-A-T м¶ңмІҳ мӢ лў°лҸ„ мӢ нҳё) -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'ConfigDeck',
        url: siteUrl.href,
        logo: new URL('/favicon.svg', siteUrl).href,
      })}
    />
    {
      jsonLd.map((data) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify({ '@context': 'https://schema.org', ...data })}
        />
      ))
    }
  </head>
  <body class="flex min-h-screen flex-col bg-surface-alt font-sans text-gray-900">
    {!bare && <Header locale={locale} currentPath={currentPath ?? pagePath} />}
    {
      bare ? (
        <slot />
      ) : (
        <main class="flex-1">
          <slot />
        </main>
      )
    }
    {!bare && <Footer />}
  </body>
</html>
