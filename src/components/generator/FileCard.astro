---
import { buildLocalizedPath, type Locale } from '@/i18n'

interface Props {
  locale: Locale
  name: string
  description: string
  slug: string
  iconType: 'document' | 'code'
}

const { locale, name, description, slug, iconType } = Astro.props

const ICON_PATHS = {
  document:
    'M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z',
  code: 'M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5',
} as const
---

<a
  href={buildLocalizedPath(locale, `/generator/${slug}`)}
  class="group flex items-start gap-4 rounded-xl border border-border bg-surface p-5 transition-all hover:border-primary/50 hover:shadow-sm"
>
  <div
    class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-gray-100 text-gray-400"
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d={ICON_PATHS[iconType]}></path>
    </svg>
  </div>
  <div>
    <h4 class="font-mono text-sm font-semibold text-gray-900 group-hover:text-primary">
      {name}
    </h4>
    <p class="mt-1 text-xs leading-relaxed text-gray-500">{description}</p>
  </div>
</a>
