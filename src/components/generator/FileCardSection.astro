---
import { getTranslation, type Locale } from '@/i18n'

import FileCard from './FileCard.astro'

interface FileCardData {
  name: string
  slug: string
  descriptionEn: string
  descriptionKo: string
}

interface Props {
  locale: Locale
  categoryLabelKey: string
  files: readonly FileCardData[]
}

const { locale, categoryLabelKey, files } = Astro.props

/**
 * locale에 따라 파일 설명을 반환한다.
 */
const getLocalizedDescription = (file: FileCardData): string => {
  return locale === 'ko' ? file.descriptionKo : file.descriptionEn
}
---

<div class="mt-10 first:mt-0">
  <h3 class="flex items-center gap-3 text-sm font-semibold uppercase tracking-wider text-gray-600">
    <span class="h-px flex-1 bg-gray-300"></span>
    <span>{getTranslation(locale, categoryLabelKey)}</span>
    <span class="h-px flex-1 bg-gray-300"></span>
  </h3>
  <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      files.map((file) => (
        <FileCard
          locale={locale}
          name={file.name}
          description={getLocalizedDescription(file)}
          slug={file.slug}
        />
      ))
    }
  </div>
</div>
