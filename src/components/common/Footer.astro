---
import { getTranslation, type Locale } from '@/i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props

const footerLinks = [
  { labelKey: 'footer.github', href: '#' },
  { labelKey: 'footer.changelog', href: '#' },
  { labelKey: 'footer.feedback', href: '#' },
] as const
---

<footer class="border-t border-border">
  <div class="mx-auto max-w-7xl px-6 py-10 text-center text-sm text-gray-400">
    <p>{getTranslation(locale, 'footer.tagline')}</p>
    <div class="mt-3 flex justify-center gap-4">
      {
        footerLinks.map((link) => (
          <a href={link.href} class="hover:text-gray-600 transition-colors">
            {getTranslation(locale, link.labelKey)}
          </a>
        ))
      }
    </div>
  </div>
</footer>
