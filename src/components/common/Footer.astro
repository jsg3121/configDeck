---
const footerLinks = [
  { label: 'GitHub', href: 'https://github.com/jsg3121/configDeck' },
  { label: 'Developer', href: 'https://sungyujang.com/' },
  { label: 'Contact', href: 'mailto:xodm95@gmail.com' },
] as const
---

<footer class="border-t border-border">
  <div class="mx-auto max-w-7xl px-6 py-10 text-center text-sm text-gray-400">
    <div class="mt-3 flex justify-center gap-4">
      {
        footerLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-gray-600 transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </div>
    <p class="mt-4">&copy; {new Date().getFullYear()} ConfigDeck. All rights reserved.</p>
  </div>
</footer>
