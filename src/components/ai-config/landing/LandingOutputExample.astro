---
/**
 * 도구별 출력 예시 코드 블록.
 * 실제 generator의 출력 형식을 그대로 발췌해 사용자가 결과물을 미리 볼 수 있게 한다.
 */
import { getTranslation, type Locale } from '@/i18n'

interface Props {
  locale: Locale
  fileName: string
  code: string
}

const { locale, fileName, code } = Astro.props as Props

const tCommon = (key: string) => getTranslation(locale, `aiConfig.landing.common.${key}`)
---

<section class="mx-auto max-w-4xl px-6 py-10">
  <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400">
    {tCommon('exampleHeading')}
  </h2>
  <figure class="mt-4 overflow-hidden rounded-lg border border-border bg-white">
    <figcaption
      class="border-b border-border bg-gray-50 px-4 py-2 font-mono text-xs font-medium text-gray-700"
    >
      {fileName}
    </figcaption>
    <pre
      class="overflow-auto p-4 text-[12px] leading-relaxed whitespace-pre-wrap wrap-break-word text-gray-800"><code>{code}</code></pre>
  </figure>
</section>
