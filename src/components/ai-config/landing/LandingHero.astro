---
/**
 * AI Config 도구별 랜딩 페이지 Hero 섹션.
 * h1 + lead + 메인 생성기 CTA + 외부 공식 문서 링크.
 */
import { buildLocalizedPath, getTranslation, type Locale } from '@/i18n'

interface Props {
  locale: Locale
  /** aiConfig.landing.{i18nKey} 형식 */
  i18nKey: string
  /** 외부 공식 문서 URL */
  docsUrl: string
  /** ?focus 파라미터에 사용할 slug (ADR-0019) */
  focusSlug: 'agents-md' | 'cursor' | 'copilot' | 'claude-code' | 'agent-skills'
}

const { locale, i18nKey, docsUrl, focusSlug } = Astro.props as Props

const t = (key: string) => getTranslation(locale, `aiConfig.landing.${key}`)
const tCommon = (key: string) => getTranslation(locale, `aiConfig.landing.common.${key}`)
const generatorHref = `${buildLocalizedPath(locale, '/ai-config/generator')}?focus=${focusSlug}`
---

<header class="mx-auto max-w-4xl px-6 pt-12 pb-8">
  <h1 class="text-3xl font-extrabold tracking-tight text-gray-900 lg:text-4xl">
    {t(`${i18nKey}.h1`)}
  </h1>
  <p class="mt-4 max-w-3xl text-lg text-gray-600">
    {t(`${i18nKey}.lead`)}
  </p>
  <p class="mt-3 max-w-3xl text-sm text-gray-500">
    {t(`${i18nKey}.intro`)}
  </p>
  <div class="mt-6 flex flex-wrap items-center gap-3">
    <a
      href={generatorHref}
      class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary-hover"
    >
      {tCommon('ctaButton')}
    </a>
    <a
      href={docsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-medium text-primary underline-offset-2 hover:underline"
    >
      {tCommon('officialDocs')}
    </a>
  </div>
</header>
