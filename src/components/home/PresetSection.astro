---
import { buildLocalizedPath, getTranslation, type Locale } from '@/i18n'

import { getStackIcon } from '@/lib/data/icons'

interface Props {
  locale: Locale
}

const { locale } = Astro.props

const presetCards = [
  { name: 'React + Vite + TS', fileCount: 7, slug: 'react-vite-ts' },
  { name: 'Next.js + TS', fileCount: 6, slug: 'nextjs' },
  { name: 'Astro + TS', fileCount: 5, slug: 'astro' },
  { name: 'Node.js + TS', fileCount: 5, slug: 'node-api' },
] as const
---

<section class="mx-auto max-w-7xl px-6 pb-20">
  <h2 class="text-center text-2xl font-bold">
    {getTranslation(locale, 'home.popularPresets')}
  </h2>
  <p class="mt-2 text-center text-gray-500">
    {getTranslation(locale, 'home.popularPresetsDescription')}
  </p>
  <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {
      presetCards.map((preset) => (
        <a
          href={buildLocalizedPath(locale, `/generator/${preset.slug}`)}
          class="group rounded-xl border border-border bg-surface p-6 transition-[transform,box-shadow,border-color] duration-200 hover:border-primary hover:shadow-lg motion-safe:hover:-translate-y-0.5"
        >
          {(() => {
            const icon = getStackIcon(preset.slug)
            return icon ? (
              <svg
                class="h-8 w-8"
                viewBox="0 0 24 24"
                fill={icon.color}
                role="img"
                aria-label={preset.name}
              >
                <path d={icon.path} />
              </svg>
            ) : null
          })()}
          <h3 class="mt-3 font-semibold text-gray-900 group-hover:text-primary">{preset.name}</h3>
          <p class="mt-1 text-sm text-gray-500">
            {preset.fileCount} {getTranslation(locale, 'generator.configFiles')}
          </p>
        </a>
      ))
    }
  </div>
</section>
