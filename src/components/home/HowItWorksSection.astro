---
import { getTranslation, getTranslationRaw, type Locale } from '@/i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props

const steps = getTranslationRaw(locale, 'home.steps') as Array<{
  title: string
  description: string
}>
---

<section class="border-y border-border bg-surface">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <h2 class="text-center text-2xl font-bold">
      {getTranslation(locale, 'home.howItWorks')}
    </h2>
    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {
        steps.map((step, index) => (
          <div class="text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-lg font-bold text-primary">
              {index + 1}
            </div>
            <h3 class="mt-4 font-semibold">{step.title}</h3>
            <p class="mt-2 text-sm text-gray-500">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
