---
import { buildLocalizedPath, getTranslation, type Locale } from '@/i18n'

import { FILE_DEFINITIONS } from '@/lib/data/files'
import { getIconBySlug } from '@/lib/data/icons'

interface Props {
  locale: Locale
}

const { locale } = Astro.props

/**
 * 지원 파일 목록은 FILE_DEFINITIONS를 단일 원본으로 사용한다.
 * 새로운 파일 추가 시 이 섹션이 자동으로 동기화되도록 하기 위함.
 */
const supportedFiles = FILE_DEFINITIONS.map((file) => ({
  name: file.fileName,
  slug: file.slug,
  description: locale === 'ko' ? file.descriptionKo : file.descriptionEn,
}))
---

<section class="mx-auto max-w-7xl px-6 py-20">
  <div class="text-center">
    <h2 class="text-3xl font-bold tracking-tight lg:text-4xl">
      {getTranslation(locale, 'home.supportedFiles')}
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-gray-500">
      {getTranslation(locale, 'home.supportedFilesDescription')}
    </p>
  </div>

  <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      supportedFiles.map((file) => (
        <a
          href={buildLocalizedPath(locale, `/generator/${file.slug}`)}
          class="group flex items-start gap-4 rounded-xl border border-border bg-surface p-5 transition-[transform,box-shadow,border-color] duration-200 hover:border-primary hover:shadow-md motion-safe:hover:-translate-y-0.5"
        >
          {(() => {
            const icon = getIconBySlug(file.slug)
            return (
              <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-gray-100 transition-colors group-hover:bg-primary/10">
                {icon ? (
                  <svg
                    class="h-5 w-5"
                    viewBox="0 0 24 24"
                    fill={icon.color}
                    role="img"
                    aria-label={file.name}
                  >
                    <path d={icon.path} />
                  </svg>
                ) : (
                  <span class="font-mono text-xs text-gray-500">{'{}'}</span>
                )}
              </div>
            )
          })()}
          <div class="min-w-0 flex-1">
            <h3 class="font-mono text-sm font-semibold text-gray-900 group-hover:text-primary">
              {file.name}
            </h3>
            <p class="mt-1 text-xs leading-relaxed text-gray-500">{file.description}</p>
          </div>
        </a>
      ))
    }
  </div>
</section>
