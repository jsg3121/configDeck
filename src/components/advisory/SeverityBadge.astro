---
/**
 * Advisory severity 배지.
 *
 * SPEC-0006-design §8.1: 색상만으로 정보를 전달하지 않으며, 색상 + 텍스트 레이블 + aria-label을 동시에 제공한다 (WCAG 1.4.1).
 * 텍스트 레이블은 국제 표준이므로 영어 대문자(CRITICAL/HIGH/...)로 고정하며, aria-label만 로케일별로 분기한다.
 */
import type { Locale } from '@/i18n'

interface Props {
  severity: 'low' | 'medium' | 'high' | 'critical'
  cvssScore?: number
  /** aria-label에서 사용할 로케일 (생략 시 영어) */
  locale?: Locale
  /** 카탈로그용 작은 배지 vs 상세용 일반 배지 (기본 normal) */
  size?: 'sm' | 'normal'
}

const { severity, cvssScore, locale = 'en', size = 'normal' } = Astro.props

const SEVERITY_LABEL: Record<Props['severity'], string> = {
  critical: 'CRITICAL',
  high: 'HIGH',
  medium: 'MEDIUM',
  low: 'LOW',
}

// SPEC-0006-design §8.1 색조 매핑
const SEVERITY_BG: Record<Props['severity'], string> = {
  critical: 'bg-red-100 text-red-800',
  high: 'bg-orange-100 text-orange-800',
  medium: 'bg-yellow-100 text-yellow-800',
  low: 'bg-blue-100 text-blue-800',
}

const SEVERITY_LABEL_LOCALIZED: Record<Locale, Record<Props['severity'], string>> = {
  en: {
    critical: 'Critical',
    high: 'High',
    medium: 'Medium',
    low: 'Low',
  },
  ko: {
    critical: 'Critical',
    high: 'High',
    medium: 'Medium',
    low: 'Low',
  },
}

const ariaLabelPrefix: Record<Locale, string> = {
  en: 'Severity',
  ko: '심각도',
}

const ariaLabel = `${ariaLabelPrefix[locale]}: ${SEVERITY_LABEL_LOCALIZED[locale][severity]}${
  cvssScore !== undefined ? ` (${cvssScore})` : ''
}`

const padding = size === 'sm' ? 'px-2.5 py-0.5 text-xs' : 'px-3 py-1 text-xs'
---

<span
  class:list={[
    'inline-flex items-center gap-1 rounded-full font-semibold',
    padding,
    SEVERITY_BG[severity],
  ]}
  aria-label={ariaLabel}
>
  {size === 'normal' && <span aria-hidden="true">●</span>}
  {SEVERITY_LABEL[severity]}
</span>
