---
import '@/styles/global.css'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ESLint Config Generator — ConfigDeck</title>
  </head>
  <body class="bg-surface-alt text-gray-900 font-sans">
    <!-- Header -->
    <header class="bg-surface border-b border-border">
      <div class="mx-auto max-w-7xl flex items-center justify-between px-6 py-4">
        <a href="/prototype/" class="text-xl font-bold tracking-tight">
          <span class="text-primary">Config</span>Deck
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
          <a href="/prototype/generator" class="hover:text-gray-900">Generator</a>
          <a href="#" class="hover:text-gray-900">Docs</a>
          <a href="#" class="hover:text-gray-900">Blog</a>
        </nav>
        <div class="flex items-center gap-3">
          <button class="text-sm text-gray-500 hover:text-gray-900">EN</button>
          <a
            href="/prototype/generator"
            class="rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-hover"
          >
            Get Started
          </a>
        </div>
      </div>
    </header>

    <!-- Main: 2-panel layout -->
    <main class="flex flex-col lg:flex-row">
      <!-- Left Panel: Settings -->
      <div class="w-full lg:w-1/2 lg:overflow-y-auto lg:h-[calc(100vh-65px)]">
        <div class="mx-auto max-w-xl px-6 py-8">
          <!-- Back link -->
          <a
            href="/prototype/generator"
            class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Generator
          </a>

          <!-- File title -->
          <div class="mt-6">
            <h1 class="text-2xl font-bold tracking-tight">
              <span class="font-mono">eslint.config.mjs</span>
            </h1>
            <p class="mt-2 text-sm text-gray-500">
              Generate a modern ESLint flat config with TypeScript, framework support, and custom
              rules.
            </p>
          </div>

          <!-- Preset buttons -->
          <div class="mt-6 border-b border-border pb-6">
            <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400">Preset</h2>
            <div class="mt-3 flex gap-2">
              <button
                class="rounded-md px-3 py-1.5 text-sm font-medium border border-border text-gray-600 hover:border-primary hover:text-primary"
              >
                Minimal
              </button>
              <button
                class="rounded-md px-3 py-1.5 text-sm font-medium bg-primary text-white border border-primary"
              >
                Recommended
              </button>
              <button
                class="rounded-md px-3 py-1.5 text-sm font-medium border border-border text-gray-600 hover:border-primary hover:text-primary"
              >
                Strict
              </button>
            </div>
          </div>

          <!-- Language section -->
          <fieldset class="border-b border-border py-6">
            <legend class="text-sm font-semibold text-gray-900">Language</legend>
            <p class="mt-1 text-xs text-gray-400">Choose the base language for your project.</p>
            <div class="mt-4 flex flex-col gap-3">
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="radio"
                  name="language"
                  value="javascript"
                  class="h-4 w-4 text-primary accent-primary"
                />
                <span class="text-sm text-gray-700">JavaScript</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="radio"
                  name="language"
                  value="typescript"
                  checked
                  class="h-4 w-4 text-primary accent-primary"
                />
                <span class="text-sm text-gray-700">TypeScript</span>
              </label>
            </div>
          </fieldset>

          <!-- Framework section -->
          <fieldset class="border-b border-border py-6">
            <legend class="text-sm font-semibold text-gray-900">Framework</legend>
            <p class="mt-1 text-xs text-gray-400">
              Select your project framework for tailored rules.
            </p>
            <div class="mt-4 flex flex-col gap-3">
              {
                ['None', 'React', 'Vue', 'Next.js', 'Node'].map((fw) => (
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="radio"
                      name="framework"
                      value={fw.toLowerCase()}
                      checked={fw === 'None'}
                      class="h-4 w-4 text-primary accent-primary"
                    />
                    <span class="text-sm text-gray-700">{fw}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>

          <!-- Rules section -->
          <fieldset class="border-b border-border py-6">
            <legend class="text-sm font-semibold text-gray-900">Rules</legend>
            <p class="mt-1 text-xs text-gray-400">Enable individual lint rules for your project.</p>
            <div class="mt-4 flex flex-col gap-3">
              {
                [
                  { label: 'Import sorting', checked: true },
                  { label: 'No console (warn)', checked: true },
                  { label: 'Prefer const', checked: true },
                  { label: 'No unused vars', checked: false },
                ].map((rule) => (
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="checkbox"
                      checked={rule.checked}
                      class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                    />
                    <span class="text-sm text-gray-700">{rule.label}</span>
                  </label>
                ))
              }
            </div>

            <!-- Strictness level dropdown -->
            <div class="mt-5">
              <label for="strictness" class="block text-sm font-medium text-gray-700">
                Strictness level
              </label>
              <select
                id="strictness"
                class="mt-1.5 block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-gray-700 focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none"
              >
                <option>Relaxed</option>
                <option selected>Recommended</option>
                <option>Strict</option>
              </select>
            </div>
          </fieldset>

          <!-- Integrations section -->
          <fieldset class="border-b border-border py-6">
            <legend class="text-sm font-semibold text-gray-900">Integrations</legend>
            <p class="mt-1 text-xs text-gray-400">
              Add support for additional tools and frameworks.
            </p>
            <div class="mt-4 flex flex-col gap-3">
              {
                [
                  { label: 'Prettier integration', checked: true },
                  { label: 'Svelte support', checked: false },
                  { label: 'Astro support', checked: false },
                ].map((item) => (
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="checkbox"
                      checked={item.checked}
                      class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                    />
                    <span class="text-sm text-gray-700">{item.label}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>

          <!-- Advanced Options -->
          <div class="py-6">
            <details open>
              <summary class="cursor-pointer text-sm font-semibold text-gray-900 select-none">
                Advanced Options
              </summary>
              <div class="mt-4 flex flex-col gap-3">
                <label class="flex items-center gap-3 cursor-pointer">
                  <input
                    type="checkbox"
                    class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                  />
                  <span class="text-sm text-gray-700">Enable flat config compat utility</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input
                    type="checkbox"
                    class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                  />
                  <span class="text-sm text-gray-700">Add ignore patterns (node_modules, dist)</span
                  >
                </label>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input
                    type="checkbox"
                    checked
                    class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                  />
                  <span class="text-sm text-gray-700">Include TypeScript strict rules</span>
                </label>
              </div>
            </details>
          </div>
        </div>
      </div>

      <!-- Right Panel: Preview -->
      <div
        class="w-full lg:w-1/2 lg:sticky lg:top-0 lg:h-screen border-t border-border lg:border-t-0 lg:border-l"
      >
        <div class="flex h-full flex-col bg-code-bg">
          <!-- Top bar -->
          <div class="flex items-center justify-between border-b border-gray-700 px-5 py-3">
            <span class="font-mono text-sm text-gray-300">eslint.config.mjs</span>
            <div class="flex items-center gap-2">
              <button
                class="inline-flex items-center gap-1.5 rounded-md border border-gray-600 px-3 py-1.5 text-xs font-medium text-gray-300 hover:bg-gray-700 hover:text-white"
              >
                <svg
                  class="h-3.5 w-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                  ></path>
                </svg>
                Copy
              </button>
              <button
                class="inline-flex items-center gap-1.5 rounded-md border border-gray-600 px-3 py-1.5 text-xs font-medium text-gray-300 hover:bg-gray-700 hover:text-white"
              >
                <svg
                  class="h-3.5 w-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Download
              </button>
            </div>
          </div>

          <!-- Code preview -->
          <div class="flex-1 overflow-auto p-5">
            <pre
              class="font-mono text-sm leading-relaxed text-gray-300"><code><span class="text-gray-500">// eslint.config.mjs</span>
<span class="text-purple-400">import</span> <span class="text-blue-300">eslintPluginAstro</span> <span class="text-purple-400">from</span> <span class="text-green-400">'eslint-plugin-astro'</span>
<span class="text-purple-400">import</span> <span class="text-blue-300">tseslint</span> <span class="text-purple-400">from</span> <span class="text-green-400">'typescript-eslint'</span>

<span class="text-purple-400">export default</span> [
  ...<span class="text-blue-300">tseslint</span>.<span class="text-blue-300">configs</span>.<span class="text-blue-300">strict</span>,
  ...<span class="text-blue-300">eslintPluginAstro</span>.<span class="text-blue-300">configs</span>.<span class="text-blue-300">recommended</span>,
  &#123;
    <span class="text-blue-300">rules</span>: &#123;
      <span class="text-green-400">'no-console'</span>: <span class="text-green-400">'warn'</span>,
      <span class="text-green-400">'prefer-const'</span>: <span class="text-green-400">'error'</span>,
      <span class="text-green-400">'no-var'</span>: <span class="text-green-400">'error'</span>,
      <span class="text-green-400">'@typescript-eslint/no-explicit-any'</span>: <span class="text-green-400">'error'</span>,
    &#125;,
  &#125;,
]</code></pre>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
