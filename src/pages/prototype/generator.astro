---
import '@/styles/global.css'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Config Generator — ConfigDeck</title>
  </head>
  <body class="bg-surface-alt text-gray-900 font-sans">
    <!-- Header -->
    <header class="bg-surface border-b border-border">
      <div class="mx-auto max-w-7xl flex items-center justify-between px-6 py-4">
        <a href="/prototype/" class="text-xl font-bold tracking-tight">
          <span class="text-primary">Config</span>Deck
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
          <a href="/prototype/generator" class="text-gray-900">Generator</a>
          <a href="#" class="hover:text-gray-900">Docs</a>
          <a href="#" class="hover:text-gray-900">Blog</a>
        </nav>
        <div class="flex items-center gap-3">
          <button class="text-sm text-gray-500 hover:text-gray-900">EN</button>
          <a
            href="/prototype/generator"
            class="rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-hover"
          >
            Get Started
          </a>
        </div>
      </div>
    </header>

    <!-- Page Title -->
    <section class="mx-auto max-w-7xl px-6 pt-16 pb-10">
      <h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl">Config Generator</h1>
      <p class="mt-4 max-w-2xl text-lg text-gray-500">
        Generate production-ready config files for your project. Start with a stack preset or pick
        individual files.
      </p>
    </section>

    <!-- Stack Presets -->
    <section class="mx-auto max-w-7xl px-6 pb-16">
      <div class="flex items-center gap-3">
        <h2 class="text-2xl font-bold">Stack Presets</h2>
        <span class="rounded-full bg-primary/10 px-3 py-0.5 text-xs font-semibold text-primary">
          Quick Start
        </span>
      </div>
      <p class="mt-2 text-gray-500">
        Pre-configured bundles for popular stacks. Pick one to generate all config files at once.
      </p>

      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          [
            {
              name: 'React + Vite + TS',
              icon: '\u269B\uFE0F',
              fileCount: 7,
              files: [
                '.gitignore',
                '.editorconfig',
                'tsconfig.json',
                'eslint.config.mjs',
                'prettier.config.mjs',
                'vite.config.ts',
                'vitest.config.ts',
              ],
            },
            {
              name: 'Next.js + TS',
              icon: '\u25B2',
              fileCount: 6,
              files: [
                '.gitignore',
                '.editorconfig',
                'tsconfig.json',
                'eslint.config.mjs',
                'prettier.config.mjs',
                'next.config.js',
              ],
            },
            {
              name: 'Astro + TS',
              icon: '\uD83D\uDE80',
              fileCount: 5,
              files: [
                '.gitignore',
                '.editorconfig',
                'tsconfig.json',
                'eslint.config.mjs',
                'prettier.config.mjs',
              ],
            },
            {
              name: 'Node API + TS',
              icon: '\uD83D\uDFE2',
              fileCount: 5,
              files: [
                '.gitignore',
                '.editorconfig',
                'tsconfig.json',
                'eslint.config.mjs',
                'prettier.config.mjs',
              ],
            },
          ].map((preset) => (
            <a
              href="/prototype/generator-stack"
              class="group flex flex-col rounded-xl border border-border bg-surface p-6 hover:border-primary hover:shadow-md transition-all"
            >
              <div class="text-3xl">{preset.icon}</div>
              <h3 class="mt-3 text-lg font-semibold text-gray-900 group-hover:text-primary">
                {preset.name}
              </h3>
              <p class="mt-1 text-sm text-gray-500">{preset.fileCount} config files</p>
              <ul class="mt-4 flex flex-wrap gap-1.5">
                {preset.files.map((file) => (
                  <li class="rounded bg-gray-100 px-2 py-0.5 font-mono text-xs text-gray-600">
                    {file}
                  </li>
                ))}
              </ul>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-7xl px-6">
      <hr class="border-border" />
    </div>

    <!-- Individual Config Files -->
    <section class="mx-auto max-w-7xl px-6 py-16">
      <h2 class="text-2xl font-bold">Individual Config Files</h2>
      <p class="mt-2 text-gray-500">
        Generate a single config file with full option control and live preview.
      </p>

      <!-- Common -->
      <div class="mt-10">
        <h3
          class="flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-gray-400"
        >
          <span class="h-px flex-1 bg-border"></span>
          <span>Common</span>
          <span class="h-px flex-1 bg-border"></span>
        </h3>
        <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            [
              {
                name: '.gitignore',
                desc: 'Git ignore patterns for your OS, IDE, and framework',
              },
              {
                name: '.editorconfig',
                desc: 'Consistent coding styles across editors and IDEs',
              },
              {
                name: '.env.example',
                desc: 'Environment variable template for team onboarding',
              },
            ].map((file) => (
              <a
                href="/prototype/generator-file"
                class="group flex items-start gap-4 rounded-xl border border-border bg-surface p-5 hover:border-primary/50 hover:shadow-sm transition-all"
              >
                <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-gray-100 text-gray-400">
                  <svg
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
                    />
                  </svg>
                </div>
                <div>
                  <h4 class="font-mono text-sm font-semibold text-gray-900 group-hover:text-primary">
                    {file.name}
                  </h4>
                  <p class="mt-1 text-xs text-gray-500 leading-relaxed">{file.desc}</p>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Frontend / Node -->
      <div class="mt-12">
        <h3
          class="flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-gray-400"
        >
          <span class="h-px flex-1 bg-border"></span>
          <span>Frontend / Node</span>
          <span class="h-px flex-1 bg-border"></span>
        </h3>
        <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            [
              {
                name: 'tsconfig.json',
                desc: 'TypeScript compiler options, path aliases, and strict mode settings',
              },
              {
                name: 'eslint.config.mjs',
                desc: 'ESLint flat config with TypeScript, React/Vue, and import sorting',
              },
              {
                name: 'prettier.config.mjs',
                desc: 'Code formatting rules for quotes, semicolons, and trailing commas',
              },
              {
                name: 'vite.config.ts',
                desc: 'Vite bundler setup with plugins, aliases, and dev server options',
              },
              {
                name: 'vitest.config.ts',
                desc: 'Vitest test runner with coverage, environment, and setup files',
              },
              {
                name: 'next.config.js',
                desc: 'Next.js configuration for images, redirects, and webpack customization',
              },
            ].map((file) => (
              <a
                href="/prototype/generator-file"
                class="group flex items-start gap-4 rounded-xl border border-border bg-surface p-5 hover:border-primary/50 hover:shadow-sm transition-all"
              >
                <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-gray-100 text-gray-400">
                  <svg
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"
                    />
                  </svg>
                </div>
                <div>
                  <h4 class="font-mono text-sm font-semibold text-gray-900 group-hover:text-primary">
                    {file.name}
                  </h4>
                  <p class="mt-1 text-xs text-gray-500 leading-relaxed">{file.desc}</p>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-border">
      <div class="mx-auto max-w-7xl px-6 py-10 text-center text-sm text-gray-400">
        <p>ConfigDeck — Build project config files with stack-based presets.</p>
        <div class="mt-3 flex justify-center gap-4">
          <a href="#" class="hover:text-gray-600">GitHub</a>
          <a href="#" class="hover:text-gray-600">Changelog</a>
          <a href="#" class="hover:text-gray-600">Feedback</a>
        </div>
      </div>
    </footer>
  </body>
</html>
