---
import '@/styles/global.css'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>React + Vite + TypeScript Generator — ConfigDeck</title>
  </head>
  <body class="bg-surface-alt text-gray-900 font-sans">
    <!-- Header -->
    <header class="bg-surface border-b border-border">
      <div class="mx-auto max-w-7xl flex items-center justify-between px-6 py-4">
        <a href="/prototype/" class="text-xl font-bold tracking-tight">
          <span class="text-primary">Config</span>Deck
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
          <a href="/prototype/generator" class="hover:text-gray-900">Generator</a>
          <a href="#" class="hover:text-gray-900">Docs</a>
          <a href="#" class="hover:text-gray-900">Blog</a>
        </nav>
        <div class="flex items-center gap-3">
          <button class="text-sm text-gray-500 hover:text-gray-900">EN</button>
          <a
            href="/prototype/generator"
            class="rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-hover"
          >
            Get Started
          </a>
        </div>
      </div>
    </header>

    <!-- Main: 2-panel layout -->
    <main class="flex flex-col lg:flex-row">
      <!-- Left Panel: Settings -->
      <div class="w-full lg:w-1/2 lg:overflow-y-auto lg:h-[calc(100vh-65px)]">
        <div class="mx-auto max-w-xl px-6 py-8">
          <!-- Back link -->
          <a
            href="/prototype/generator"
            class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Generator
          </a>

          <!-- Stack title -->
          <div class="mt-6">
            <div class="flex items-center gap-3">
              <span class="text-3xl" role="img" aria-label="React icon">&#9883;&#65039;</span>
              <h1 class="text-2xl font-bold tracking-tight">React + Vite + TypeScript</h1>
            </div>
            <p class="mt-2 text-sm text-gray-500">
              Generate all essential config files for a React project powered by Vite and
              TypeScript. Includes linting, formatting, and build configuration.
            </p>
          </div>

          <!-- Included files checklist -->
          <fieldset class="mt-6 border-b border-border pb-6">
            <legend class="text-xs font-semibold uppercase tracking-wider text-gray-400">
              Included Files
            </legend>
            <div class="mt-3 flex flex-col gap-2.5">
              {
                [
                  '.gitignore',
                  '.editorconfig',
                  'tsconfig.json',
                  'eslint.config.mjs',
                  'prettier.config.mjs',
                  'vite.config.ts',
                  'vitest.config.ts',
                ].map((file) => (
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="checkbox"
                      checked
                      class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                    />
                    <span class="font-mono text-sm text-gray-700">{file}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>

          <!-- File options accordions -->

          <!-- .gitignore options -->
          <details open class="border-b border-border py-5 group">
            <summary class="cursor-pointer select-none flex items-center justify-between">
              <span class="text-sm font-semibold text-gray-900">.gitignore</span>
              <svg
                class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div class="mt-4 flex flex-col gap-3 pl-1">
              <p class="text-xs text-gray-400">Select which patterns to include.</p>
              {
                [
                  { label: 'Node (node_modules, npm-debug.log)', checked: true },
                  { label: 'macOS (.DS_Store, .AppleDouble)', checked: true },
                  { label: 'VS Code (.vscode/, *.code-workspace)', checked: true },
                ].map((item) => (
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="checkbox"
                      checked={item.checked}
                      class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                    />
                    <span class="text-sm text-gray-700">{item.label}</span>
                  </label>
                ))
              }
            </div>
          </details>

          <!-- tsconfig.json options -->
          <details open class="border-b border-border py-5 group">
            <summary class="cursor-pointer select-none flex items-center justify-between">
              <span class="text-sm font-semibold text-gray-900">tsconfig.json</span>
              <svg
                class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div class="mt-4 flex flex-col gap-4 pl-1">
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  checked
                  class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                />
                <span class="text-sm text-gray-700">Enable strict mode</span>
              </label>

              <div>
                <label for="path-alias" class="block text-sm font-medium text-gray-700">
                  Path alias
                </label>
                <input
                  type="text"
                  id="path-alias"
                  value="@/*"
                  class="mt-1.5 block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-gray-700 font-mono focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none"
                />
              </div>

              <div>
                <label for="target" class="block text-sm font-medium text-gray-700">Target</label>
                <select
                  id="target"
                  class="mt-1.5 block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-gray-700 focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none"
                >
                  <option>ES2020</option>
                  <option selected>ES2022</option>
                  <option>ES2023</option>
                  <option>ESNext</option>
                </select>
              </div>
            </div>
          </details>

          <!-- eslint.config.mjs options -->
          <details open class="border-b border-border py-5 group">
            <summary class="cursor-pointer select-none flex items-center justify-between">
              <span class="text-sm font-semibold text-gray-900">eslint.config.mjs</span>
              <svg
                class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div class="mt-4 flex flex-col gap-4 pl-1">
              <fieldset>
                <legend class="text-xs font-medium text-gray-500 uppercase tracking-wider">
                  Language
                </legend>
                <div class="mt-2 flex flex-col gap-2">
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="radio"
                      name="eslint-lang"
                      value="javascript"
                      class="h-4 w-4 text-primary accent-primary"
                    />
                    <span class="text-sm text-gray-700">JavaScript</span>
                  </label>
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="radio"
                      name="eslint-lang"
                      value="typescript"
                      checked
                      class="h-4 w-4 text-primary accent-primary"
                    />
                    <span class="text-sm text-gray-700">TypeScript</span>
                  </label>
                </div>
              </fieldset>

              <fieldset>
                <legend class="text-xs font-medium text-gray-500 uppercase tracking-wider">
                  Framework
                </legend>
                <div class="mt-2 flex flex-col gap-2">
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="radio"
                      name="eslint-framework"
                      value="none"
                      class="h-4 w-4 text-primary accent-primary"
                    />
                    <span class="text-sm text-gray-700">None</span>
                  </label>
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="radio"
                      name="eslint-framework"
                      value="react"
                      checked
                      class="h-4 w-4 text-primary accent-primary"
                    />
                    <span class="text-sm text-gray-700">React</span>
                  </label>
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="radio"
                      name="eslint-framework"
                      value="vue"
                      class="h-4 w-4 text-primary accent-primary"
                    />
                    <span class="text-sm text-gray-700">Vue</span>
                  </label>
                </div>
              </fieldset>

              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  checked
                  class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                />
                <span class="text-sm text-gray-700">Prettier integration</span>
              </label>
            </div>
          </details>

          <!-- prettier.config.mjs options -->
          <details class="border-b border-border py-5 group">
            <summary class="cursor-pointer select-none flex items-center justify-between">
              <span class="text-sm font-semibold text-gray-900">prettier.config.mjs</span>
              <svg
                class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div class="mt-4 flex flex-col gap-4 pl-1">
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  checked
                  class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                />
                <span class="text-sm text-gray-700">singleQuote</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                />
                <span class="text-sm text-gray-700">semi</span>
              </label>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="tab-width" class="block text-sm font-medium text-gray-700">
                    tabWidth
                  </label>
                  <select
                    id="tab-width"
                    class="mt-1.5 block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-gray-700 focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none"
                  >
                    <option selected>2</option>
                    <option>4</option>
                  </select>
                </div>
                <div>
                  <label for="print-width" class="block text-sm font-medium text-gray-700">
                    printWidth
                  </label>
                  <select
                    id="print-width"
                    class="mt-1.5 block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-gray-700 focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none"
                  >
                    <option>80</option>
                    <option selected>100</option>
                    <option>120</option>
                  </select>
                </div>
              </div>
            </div>
          </details>

          <!-- vite.config.ts options (collapsed) -->
          <details class="border-b border-border py-5 group">
            <summary class="cursor-pointer select-none flex items-center justify-between">
              <span class="text-sm font-semibold text-gray-900">vite.config.ts</span>
              <svg
                class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div class="mt-4 flex flex-col gap-3 pl-1">
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  checked
                  class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                />
                <span class="text-sm text-gray-700">React plugin (@vitejs/plugin-react)</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  checked
                  class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                />
                <span class="text-sm text-gray-700">Path alias resolve (@/)</span>
              </label>
            </div>
          </details>

          <!-- vitest.config.ts options (collapsed) -->
          <details class="py-5 group">
            <summary class="cursor-pointer select-none flex items-center justify-between">
              <span class="text-sm font-semibold text-gray-900">vitest.config.ts</span>
              <svg
                class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div class="mt-4 flex flex-col gap-3 pl-1">
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  checked
                  class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                />
                <span class="text-sm text-gray-700">jsdom environment</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                />
                <span class="text-sm text-gray-700">Coverage reporter (v8)</span>
              </label>
            </div>
          </details>
        </div>
      </div>

      <!-- Right Panel: Preview -->
      <div
        class="w-full lg:w-1/2 lg:sticky lg:top-0 lg:h-screen border-t border-border lg:border-t-0 lg:border-l"
      >
        <div class="flex h-full flex-col bg-code-bg">
          <!-- File tabs -->
          <div class="overflow-x-auto border-b border-gray-700">
            <div class="flex">
              {
                [
                  { name: 'tsconfig.json', active: true },
                  { name: '.gitignore', active: false },
                  { name: '.editorconfig', active: false },
                  { name: 'eslint.config.mjs', active: false },
                  { name: 'prettier.config.mjs', active: false },
                  { name: 'vite.config.ts', active: false },
                  { name: 'vitest.config.ts', active: false },
                ].map((tab) => (
                  <button
                    class:list={[
                      'shrink-0 px-4 py-2.5 text-xs font-mono font-medium border-b-2 transition-colors',
                      tab.active
                        ? 'border-primary text-white bg-gray-800'
                        : 'border-transparent text-gray-500 hover:text-gray-300 hover:bg-gray-800/50',
                    ]}
                  >
                    {tab.name}
                  </button>
                ))
              }
            </div>
          </div>

          <!-- Action bar -->
          <div class="flex items-center justify-end gap-2 border-b border-gray-700 px-5 py-2.5">
            <button
              class="inline-flex items-center gap-1.5 rounded-md border border-gray-600 px-3 py-1.5 text-xs font-medium text-gray-300 hover:bg-gray-700 hover:text-white"
            >
              <svg
                class="h-3.5 w-3.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                ></path>
              </svg>
              Copy
            </button>
            <button
              class="inline-flex items-center gap-1.5 rounded-md border border-gray-600 px-3 py-1.5 text-xs font-medium text-gray-300 hover:bg-gray-700 hover:text-white"
            >
              <svg
                class="h-3.5 w-3.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
              </svg>
              Download
            </button>
            <button
              class="inline-flex items-center gap-1.5 rounded-md bg-accent px-3.5 py-1.5 text-xs font-medium text-white hover:bg-accent/90"
            >
              <svg
                class="h-3.5 w-3.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
              </svg>
              Download All (ZIP)
            </button>
          </div>

          <!-- Code preview -->
          <div class="flex-1 overflow-auto p-5">
            <pre
              class="font-mono text-sm leading-relaxed text-gray-300"><code>&#123;
  <span class="text-blue-300">"compilerOptions"</span>: &#123;
    <span class="text-blue-300">"target"</span>: <span class="text-green-400">"ES2022"</span>,
    <span class="text-blue-300">"module"</span>: <span class="text-green-400">"ESNext"</span>,
    <span class="text-blue-300">"moduleResolution"</span>: <span class="text-green-400">"bundler"</span>,
    <span class="text-blue-300">"strict"</span>: <span class="text-orange-400">true</span>,
    <span class="text-blue-300">"jsx"</span>: <span class="text-green-400">"react-jsx"</span>,
    <span class="text-blue-300">"baseUrl"</span>: <span class="text-green-400">"."</span>,
    <span class="text-blue-300">"paths"</span>: &#123;
      <span class="text-blue-300">"@/*"</span>: [<span class="text-green-400">"src/*"</span>]
    &#125;,
    <span class="text-blue-300">"esModuleInterop"</span>: <span class="text-orange-400">true</span>,
    <span class="text-blue-300">"skipLibCheck"</span>: <span class="text-orange-400">true</span>
  &#125;,
  <span class="text-blue-300">"include"</span>: [<span class="text-green-400">"src"</span>],
  <span class="text-blue-300">"exclude"</span>: [<span class="text-green-400">"node_modules"</span>, <span class="text-green-400">"dist"</span>]
&#125;</code></pre>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
