---
/**
 * AI 도구 설정 + Skills 통합 생성기 페이지.
 *
 * SPEC-0005 메인 페이지. 사용자가 도구/Skills/Best Practices/Boundaries를
 * 선택하면 4개 AI 도구의 설정 파일과 Agent Skills SKILL.md를 생성한다.
 */
import { getTranslation, SUPPORTED_LOCALES, type Locale } from '@/i18n'

import Layout from '@/layouts/Layout.astro'
import AiConfigGenerator from '@/components/ai-config/AiConfigGenerator.svelte'

export const getStaticPaths = () => {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const siteUrl = 'https://configdeck.dev'

const title = getTranslation(locale, 'aiConfig.page.title')
const heading = getTranslation(locale, 'aiConfig.page.heading')
const description = getTranslation(locale, 'aiConfig.page.description')

// JSON-LD 구조화 데이터
const softwareApplicationJsonLd = {
  '@type': 'SoftwareApplication',
  name: 'ConfigDeck — AI Tool Config Generator',
  url: `${siteUrl}/${locale}/ai-config`,
  description,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  browserRequirements: 'Requires JavaScript',
  inLanguage: ['en', 'ko'],
}
---

<Layout
  {title}
  {description}
  {locale}
  pagePath="/ai-config"
  currentPath="/ai-config"
  jsonLd={[softwareApplicationJsonLd]}
>
  <section class="mx-auto max-w-7xl px-6 pt-12 pb-6">
    <h1 class="text-3xl font-extrabold tracking-tight lg:text-4xl">
      {heading}
    </h1>
    <p class="mt-3 max-w-3xl text-base text-gray-500">
      {description}
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-20">
    <AiConfigGenerator client:load locale={locale} />
  </section>
</Layout>
