---
/**
 * AI 도구 설정 + Skills 통합 생성기 페이지 (ADR-0019).
 *
 * SPEC-0005 메인 생성기. 사용자가 도구/Skills/Best Practices/Boundaries를
 * 선택하면 4개 AI 도구의 설정 파일과 Agent Skills SKILL.md를 생성한다.
 *
 * 카탈로그 페이지(/ai-config)에서 "통합 생성기 시작하기" CTA로 진입하거나,
 * 5개 자식 랜딩(/ai-config/{slug})에서 ?focus={slug} 파라미터로 진입한다.
 */
import { buildLocalizedPath, getTranslation, SUPPORTED_LOCALES, type Locale } from '@/i18n'

import Layout from '@/layouts/Layout.astro'
import AiConfigGenerator from '@/components/ai-config/AiConfigGenerator.svelte'

export const getStaticPaths = () => {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const siteUrl = 'https://configdeck.dev'

const title = getTranslation(locale, 'seo.aiConfigGeneratorTitle')
const description = getTranslation(locale, 'seo.aiConfigGeneratorDescription')
const heading = getTranslation(locale, 'aiConfig.page.heading')
const bodyDescription = getTranslation(locale, 'aiConfig.page.description')

const softwareApplicationJsonLd = {
  '@type': 'SoftwareApplication',
  name: 'ConfigDeck — AI Tool Config Generator',
  url: `${siteUrl}/${locale}/ai-config/generator`,
  description,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  browserRequirements: 'Requires JavaScript',
  inLanguage: locale,
}

// 카탈로그 → 생성기 IA 위계를 명시 (ADR-0019)
const breadcrumbJsonLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: getTranslation(locale, 'aiConfig.landing.common.breadcrumbHome'),
      item: `${siteUrl}/${locale}`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: getTranslation(locale, 'aiConfig.landing.common.breadcrumbHub'),
      item: `${siteUrl}/${locale}/ai-config`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: getTranslation(locale, 'aiConfig.landing.common.breadcrumbGenerator'),
      item: `${siteUrl}/${locale}/ai-config/generator`,
    },
  ],
}
---

<Layout
  {title}
  {description}
  {locale}
  pagePath="/ai-config/generator"
  currentPath="/ai-config/generator"
  jsonLd={[softwareApplicationJsonLd, breadcrumbJsonLd]}
>
  <article>
    <nav aria-label="Breadcrumb" class="mx-auto max-w-7xl px-6 pt-6 text-xs text-gray-500">
      <ol class="flex items-center gap-2">
        <li>
          <a href={buildLocalizedPath(locale, '/')} class="hover:text-gray-900">
            {getTranslation(locale, 'aiConfig.landing.common.breadcrumbHome')}
          </a>
        </li>
        <li aria-hidden="true">/</li>
        <li>
          <a href={buildLocalizedPath(locale, '/ai-config')} class="hover:text-gray-900">
            {getTranslation(locale, 'aiConfig.landing.common.breadcrumbHub')}
          </a>
        </li>
        <li aria-hidden="true">/</li>
        <li class="font-medium text-gray-900" aria-current="page">
          {getTranslation(locale, 'aiConfig.landing.common.breadcrumbGenerator')}
        </li>
      </ol>
    </nav>

    <header class="mx-auto max-w-7xl px-6 pt-8 pb-6">
      <h1 class="text-3xl font-extrabold tracking-tight lg:text-4xl">
        {heading}
      </h1>
      <p class="mt-3 max-w-3xl text-base text-gray-500">
        {bodyDescription}
      </p>
    </header>

    <section class="mx-auto max-w-7xl px-6 pb-20">
      <AiConfigGenerator client:load locale={locale} />
    </section>
  </article>
</Layout>
