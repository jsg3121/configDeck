---
import { getTranslation, SUPPORTED_LOCALES, type Locale } from '@/i18n'

import Layout from '@/layouts/Layout.astro'
import FaqSection from '@/components/home/FaqSection.astro'
import HeroSection from '@/components/home/HeroSection.astro'
import HowItWorksSection from '@/components/home/HowItWorksSection.astro'
import PresetSection from '@/components/home/PresetSection.astro'
import SupportedFilesSection from '@/components/home/SupportedFilesSection.astro'

export const getStaticPaths = () => {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }
---

<Layout
  title={getTranslation(locale, 'seo.homeTitle')}
  description={getTranslation(locale, 'seo.homeDescription')}
  locale={locale}
  pagePath="/"
>
  <HeroSection locale={locale} />
  <PresetSection locale={locale} />
  <HowItWorksSection locale={locale} />
  <SupportedFilesSection locale={locale} />
  <FaqSection locale={locale} />
</Layout>
