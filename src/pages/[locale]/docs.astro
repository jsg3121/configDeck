---
import { buildLocalizedPath, getTranslation, SUPPORTED_LOCALES, type Locale } from '@/i18n'

import Layout from '@/layouts/Layout.astro'

export const getStaticPaths = () => {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const docSections = [
  {
    titleKey: 'docs.sections.gettingStarted',
    descriptionKey: 'docs.sections.gettingStartedDescription',
    icon: '🚀',
  },
  {
    titleKey: 'docs.sections.fileGuides',
    descriptionKey: 'docs.sections.fileGuidesDescription',
    icon: '📄',
  },
  {
    titleKey: 'docs.sections.stackPresets',
    descriptionKey: 'docs.sections.stackPresetsDescription',
    icon: '📦',
  },
  {
    titleKey: 'docs.sections.migration',
    descriptionKey: 'docs.sections.migrationDescription',
    icon: '🔄',
  },
] as const
---

<Layout
  title={getTranslation(locale, 'seo.docsTitle')}
  description={getTranslation(locale, 'seo.docsDescription')}
  locale={locale}
  pagePath="/docs"
  currentPath="/docs"
>
  <section class="mx-auto max-w-7xl px-6 py-24">
    <h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl">
      {getTranslation(locale, 'docs.title')}
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-gray-500">
      {getTranslation(locale, 'docs.description')}
    </p>

    <!-- Coming Soon 배너 -->
    <div class="mt-10 rounded-xl border border-primary/20 bg-primary/5 p-8 text-center">
      <div class="text-4xl">📚</div>
      <h2 class="mt-4 text-xl font-bold text-gray-900">
        {getTranslation(locale, 'docs.comingSoon')}
      </h2>
      <p class="mt-2 text-gray-500">
        {getTranslation(locale, 'docs.comingSoonDescription')}
      </p>
      <a
        href={buildLocalizedPath(locale, '/generator')}
        class="mt-6 inline-block rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-white hover:bg-primary-hover"
      >
        {getTranslation(locale, 'home.startBuilding')}
      </a>
    </div>

    <!-- 예정 섹션 미리보기 -->
    <div class="mt-16 grid gap-6 sm:grid-cols-2">
      {
        docSections.map((section) => (
          <div class="rounded-xl border border-border bg-surface p-6 opacity-60">
            <div class="text-2xl">{section.icon}</div>
            <h3 class="mt-3 font-semibold text-gray-900">
              {getTranslation(locale, section.titleKey)}
            </h3>
            <p class="mt-1 text-sm text-gray-500">
              {getTranslation(locale, section.descriptionKey)}
            </p>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
