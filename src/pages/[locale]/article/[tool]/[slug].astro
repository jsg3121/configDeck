---
import { buildLocalizedPath, getTranslation, SUPPORTED_LOCALES, type Locale } from '@/i18n'
import { getCollection, render } from 'astro:content'

import Layout from '@/layouts/Layout.astro'
import { TOOL_COLORS_DETAILED, TOOL_TO_GENERATOR, type ArticleTool } from '@/lib/constants'

export const getStaticPaths = async () => {
  const paths = []

  try {
    const allArticles = await getCollection('articles')

    // Astro content collection glob loader는 id를 "<locale>/<slug>" 형식으로 만든다
    // (확장자는 제거됨). locale은 SUPPORTED_LOCALES로 검증해 의도치 않은 디렉토리를 거른다.
    // 향후 locale이 추가되어도 SUPPORTED_LOCALES만 갱신하면 동작이 일관된다.
    const parseArticleId = (id: string): { articleLocale: Locale; articleSlug: string } | null => {
      const [maybeLocale, ...slugParts] = id.split('/')
      if (!maybeLocale || slugParts.length === 0) return null
      if (!(SUPPORTED_LOCALES as readonly string[]).includes(maybeLocale)) return null
      return { articleLocale: maybeLocale as Locale, articleSlug: slugParts.join('/') }
    }

    // 같은 slug에 대해 어떤 locale에 글이 존재하는지 미리 집계한다.
    // article 발행 파이프라인이 한쪽 locale 검증 실패로 비대칭 발행할 수 있으므로,
    // hreflang은 실제 존재하는 locale만 가리켜야 한다 (SPEC-0007 §6.3 M5 게이트).
    const slugLocaleMap = new Map<string, Set<Locale>>()
    for (const article of allArticles) {
      const parsed = parseArticleId(article.id)
      if (!parsed) continue
      const { articleLocale, articleSlug } = parsed
      const existing = slugLocaleMap.get(articleSlug)
      if (existing) {
        existing.add(articleLocale)
      } else {
        slugLocaleMap.set(articleSlug, new Set([articleLocale]))
      }
    }

    for (const article of allArticles) {
      const parsed = parseArticleId(article.id)
      if (!parsed) continue
      const { articleLocale, articleSlug } = parsed
      const { Content } = await render(article)
      const availableLocales = Array.from(
        slugLocaleMap.get(articleSlug) ?? new Set([articleLocale]),
      )
      paths.push({
        params: { locale: articleLocale, tool: article.data.tool, slug: articleSlug },
        props: { article, Content, availableLocales },
      })
    }
  } catch {
    // 컬렉션이 비어있는 경우
  }

  return paths
}

const { locale, tool, slug } = Astro.params as { locale: Locale; tool: ArticleTool; slug: string }
const { article, Content, availableLocales } = Astro.props as {
  article: Awaited<ReturnType<typeof getCollection<'articles'>>>[number]
  Content: Awaited<ReturnType<typeof render>>['Content']
  availableLocales: Locale[]
}

const pagePath = `/article/${tool}/${slug}`
const hreflangAlternates = availableLocales.map((altLocale) => ({
  locale: altLocale,
  href: buildLocalizedPath(altLocale, pagePath),
}))

const formatDate = (date: Date): string => {
  return date.toLocaleDateString(locale === 'ko' ? 'ko-KR' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
}

const toolName = getTranslation(locale, `article.tools.${tool}`)
const pageTitle = `${article.data.title} — ${toolName} | ConfigDeck`
const pageDescription = article.data.summary

// 같은 도구의 다른 아티클 가져오기
let relatedArticles: (typeof article)[] = []
try {
  const allArticles = await getCollection('articles')
  relatedArticles = allArticles
    .filter((a) => a.id.startsWith(`${locale}/`) && a.data.tool === tool && a.id !== article.id)
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 3)
} catch {
  // 빈 배열 유지
}

// JSON-LD 구조화 데이터
const siteUrl = Astro.site?.origin ?? 'https://configdeck.dev'
const ogImageUrl = `${siteUrl}/og-image.png`

// build.format: 'file' 환경에서 Astro.url.href는 ".html"을 포함하므로,
// canonical URL과 일관되도록 .html 접미사를 제거한다. 이 변수는 JSON-LD
// `mainEntityOfPage.@id`에 사용되며, Layout이 출력하는 <link rel="canonical">과
// 정확히 동일한 URL이 된다 (Google의 페이지 식별 시그널 일관성).
const canonicalHref = Astro.url.href.replace(/\.html$/, '')

// SPEC-0007 §3.2.7 / ADR-0021 결정 8 — Editorial Commentary 모델의 BlogPosting.
// `isBasedOn`/`citation`을 명시해 Google이 이 글을 derivative work로 정당하게
// 인식하도록 한다. 페이즈 4에서 모든 글이 새 schema(sourceName/sourceUrl required)로
// 강제되므로 분기 없이 항상 commentary 블록을 출력한다.
const articleJsonLd = {
  '@type': 'BlogPosting',
  headline: article.data.title,
  description: article.data.summary,
  image: ogImageUrl,
  datePublished: article.data.pubDate.toISOString(),
  dateModified: article.data.pubDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'ConfigDeck Editorial',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'ConfigDeck',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.svg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalHref,
  },
  about: {
    '@type': 'SoftwareApplication',
    name: toolName,
  },
  isBasedOn: article.data.sourceUrl,
  citation: {
    '@type': 'CreativeWork',
    name: article.data.title,
    url: article.data.sourceUrl,
    publisher: {
      '@type': 'Organization',
      name: article.data.sourceName,
    },
  },
}

const breadcrumbJsonLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: locale === 'ko' ? '아티클' : 'Articles',
      item: `${siteUrl}/${locale}/article`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: toolName,
      item: `${siteUrl}/${locale}/article/${tool}`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: article.data.title,
    },
  ],
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  locale={locale}
  pagePath={pagePath}
  hreflangAlternates={hreflangAlternates}
  currentPath="/article"
  ogType="article"
  articlePublishedTime={article.data.pubDate}
  articleSection={toolName}
  articleTag={[tool]}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <article class="mx-auto max-w-4xl px-6 py-16">
    <!-- 뒤로가기 -->
    <a
      href={buildLocalizedPath(locale, `/article/${tool}`)}
      class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-700"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"
        ></path>
      </svg>
      {getTranslation(locale, `article.tools.${tool}`)}
      {locale === 'ko' ? ' 아티클' : ' Articles'}
    </a>

    <!-- 헤더 -->
    <header class="mt-8">
      <div class="flex flex-wrap items-center gap-3">
        <span
          class={`rounded-full px-3 py-1 text-sm font-medium ${TOOL_COLORS_DETAILED[tool].bg} ${TOOL_COLORS_DETAILED[tool].text}`}
        >
          {toolName}
        </span>
      </div>

      <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-gray-900 lg:text-4xl">
        {article.data.title}
      </h1>

      <!-- SPEC-0007 §3.2.7: 상단에는 원문 직접 링크 대신 ConfigDeck의 역할이 -->
      <!-- "코멘터리"임을 정직하게 명시한다. 외부 링크는 본문 하단의 강조 CTA로 -->
      <!-- 자연스럽게 유도해 derivative work의 정당성을 살린다.                -->
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500">
        <time datetime={article.data.pubDate.toISOString()}>
          {formatDate(article.data.pubDate)}
        </time>
        <span class="hidden sm:inline">·</span>
        <span>
          {getTranslation(locale, 'article.commentaryLabel', { source: article.data.sourceName })}
        </span>
      </div>
    </header>

    <!-- 요약 카드 -->
    <div
      class={`mt-8 rounded-xl border p-6 ${TOOL_COLORS_DETAILED[tool].bg} ${TOOL_COLORS_DETAILED[tool].border}`}
    >
      <h2 class={`text-lg font-semibold ${TOOL_COLORS_DETAILED[tool].text}`}>
        {locale === 'ko' ? '요약' : 'Summary'}
      </h2>
      <p class="mt-2 text-gray-700">{article.data.summary}</p>
    </div>

    <!-- 상세 내용 -->
    <div class="prose-content mt-10">
      <Content />
    </div>

    <!--
      SPEC-0007 §3.2.7 — 원문 안내 CTA.
      본문이 ConfigDeck 관점의 짧은 코멘터리이므로, 더 자세한 정보를 원하는 독자를
      원문으로 자연스럽게 유도한다. Schema.org `isBasedOn`/`citation`과 함께
      derivative work의 정직한 시그널 역할을 한다.
    -->
    <aside
      class="mt-10 rounded-xl border border-gray-200 bg-gray-50 p-6"
      aria-label={getTranslation(locale, 'article.sourceCalloutAriaLabel')}
    >
      <p class="text-sm text-gray-500">{getTranslation(locale, 'article.sourceCalloutNote')}</p>
      <a
        href={article.data.sourceUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 inline-flex items-center gap-2 font-semibold text-primary hover:underline"
      >
        {getTranslation(locale, 'article.sourceCalloutLink', { source: article.data.sourceName })}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
    </aside>

    <!-- 설정 생성 CTA (generator가 있는 도구만) -->
    {
      TOOL_TO_GENERATOR[tool] && (
        <div class="mt-12 rounded-xl border border-primary/20 bg-linear-to-r from-primary/5 to-primary/10 p-8">
          <div class="flex flex-col items-center text-center sm:flex-row sm:text-left">
            <div class="flex-1">
              <h2 class="text-xl font-bold text-gray-900">
                {locale === 'ko'
                  ? `${toolName} 설정 파일이 필요하신가요?`
                  : `Need a ${toolName} config file?`}
              </h2>
              <p class="mt-2 text-gray-600">
                {locale === 'ko'
                  ? 'ConfigDeck에서 최신 설정을 몇 초 만에 생성하세요.'
                  : 'Generate the latest config in seconds with ConfigDeck.'}
              </p>
            </div>
            <a
              href={buildLocalizedPath(locale, `/generator/${TOOL_TO_GENERATOR[tool]}`)}
              class="mt-4 inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 font-semibold text-white hover:bg-primary-hover sm:mt-0"
            >
              {getTranslation(locale, 'article.generateConfig')}
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"
                />
              </svg>
            </a>
          </div>
        </div>
      )
    }

    <!-- 관련 아티클 -->
    {
      relatedArticles.length > 0 && (
        <div class="mt-16">
          <h2 class="text-xl font-bold text-gray-900">
            {locale === 'ko' ? `다른 ${toolName} 소식` : `More ${toolName} Updates`}
          </h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {relatedArticles.map((related) => {
              const relatedSlug = related.id.replace(`${locale}/`, '').replace('.md', '')
              return (
                <a
                  href={buildLocalizedPath(locale, `/article/${related.data.tool}/${relatedSlug}`)}
                  class="group rounded-lg border border-border bg-white p-4 transition-shadow hover:shadow-md"
                >
                  <time class="text-xs text-gray-400">{formatDate(related.data.pubDate)}</time>
                  <h3 class="mt-2 line-clamp-2 font-semibold text-gray-900 group-hover:text-primary">
                    {related.data.title}
                  </h3>
                  <p class="mt-2 line-clamp-2 text-sm text-gray-500">{related.data.summary}</p>
                </a>
              )
            })}
          </div>
        </div>
      )
    }
  </article>
</Layout>
