---
import { buildLocalizedPath, getTranslation, SUPPORTED_LOCALES, type Locale } from '@/i18n'

import Layout from '@/layouts/Layout.astro'

export const getStaticPaths = () => {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const stackPresetCards = [
  {
    name: 'React + Vite + TS',
    icon: '\u269B\uFE0F',
    fileCount: 7,
    slug: 'react-vite-ts',
    includedFiles: [
      '.gitignore',
      '.editorconfig',
      'tsconfig.json',
      'eslint.config.mjs',
      'prettier.config.mjs',
      'vite.config.ts',
      'vitest.config.ts',
    ],
  },
  {
    name: 'Next.js + TS',
    icon: '\u25B2',
    fileCount: 6,
    slug: 'nextjs',
    includedFiles: [
      '.gitignore',
      '.editorconfig',
      'tsconfig.json',
      'eslint.config.mjs',
      'prettier.config.mjs',
      'next.config.js',
    ],
  },
  {
    name: 'Astro + TS',
    icon: '\uD83D\uDE80',
    fileCount: 5,
    slug: 'astro',
    includedFiles: [
      '.gitignore',
      '.editorconfig',
      'tsconfig.json',
      'eslint.config.mjs',
      'prettier.config.mjs',
    ],
  },
  {
    name: 'Node API + TS',
    icon: '\uD83D\uDFE2',
    fileCount: 5,
    slug: 'node-api',
    includedFiles: [
      '.gitignore',
      '.editorconfig',
      'tsconfig.json',
      'eslint.config.mjs',
      'prettier.config.mjs',
    ],
  },
] as const

const commonFileCards = [
  {
    name: '.gitignore',
    slug: 'gitignore',
    descriptionEn: 'Git ignore patterns for your OS, IDE, and framework',
    descriptionKo: 'OS, IDE, 프레임워크에 맞는 Git 무시 패턴',
  },
  {
    name: '.editorconfig',
    slug: 'editorconfig',
    descriptionEn: 'Consistent coding styles across editors and IDEs',
    descriptionKo: '에디터와 IDE 간 일관된 코딩 스타일',
  },
  {
    name: '.env.example',
    slug: 'env-example',
    descriptionEn: 'Environment variable template for team onboarding',
    descriptionKo: '팀 온보딩을 위한 환경 변수 템플릿',
  },
] as const

const frontendFileCards = [
  {
    name: 'tsconfig.json',
    slug: 'tsconfig',
    descriptionEn: 'TypeScript compiler options, path aliases, and strict mode settings',
    descriptionKo: 'TypeScript 컴파일러 옵션, 경로 별칭, strict 모드 설정',
  },
  {
    name: 'eslint.config.mjs',
    slug: 'eslint-config',
    descriptionEn: 'ESLint flat config with TypeScript, React/Vue, and import sorting',
    descriptionKo: 'TypeScript, React/Vue, import 정렬을 지원하는 ESLint flat config',
  },
  {
    name: 'prettier.config.mjs',
    slug: 'prettier-config',
    descriptionEn: 'Code formatting rules for quotes, semicolons, and trailing commas',
    descriptionKo: '따옴표, 세미콜론, 후행 쉼표 등 코드 포맷팅 규칙',
  },
  {
    name: 'vite.config.ts',
    slug: 'vite-config',
    descriptionEn: 'Vite bundler setup with plugins, aliases, and dev server options',
    descriptionKo: '플러그인, 별칭, 개발 서버 옵션이 포함된 Vite 번들러 설정',
  },
  {
    name: 'vitest.config.ts',
    slug: 'vitest-config',
    descriptionEn: 'Vitest test runner with coverage, environment, and setup files',
    descriptionKo: '커버리지, 환경, 셋업 파일이 포함된 Vitest 테스트 러너',
  },
  {
    name: 'next.config.js',
    slug: 'next-config',
    descriptionEn: 'Next.js configuration for images, redirects, and webpack customization',
    descriptionKo: '이미지, 리다이렉트, webpack 커스터마이즈를 위한 Next.js 설정',
  },
] as const

/**
 * locale에 따라 파일 설명을 반환한다.
 */
const getFileDescription = (file: { descriptionEn: string; descriptionKo: string }): string => {
  return locale === 'ko' ? file.descriptionKo : file.descriptionEn
}

/**
 * 파일 아이콘 SVG path를 카테고리에 따라 반환한다.
 * Common 파일은 문서 아이콘, Frontend/Node 파일은 코드 아이콘을 사용한다.
 */
const FILE_ICON_PATHS = {
  document:
    'M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z',
  code: 'M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5',
} as const
---

<Layout
  title={getTranslation(locale, 'seo.generatorTitle')}
  description={getTranslation(locale, 'seo.generatorDescription')}
  locale={locale}
  pagePath="/generator"
  currentPath="/generator"
>
  <!-- 페이지 타이틀 -->
  <section class="mx-auto max-w-7xl px-6 pt-16 pb-10">
    <h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl">
      {getTranslation(locale, 'generator.title')}
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-gray-500">
      {getTranslation(locale, 'generator.description')}
    </p>
  </section>

  <!-- 스택 프리셋 -->
  <section class="mx-auto max-w-7xl px-6 pb-16">
    <div class="flex items-center gap-3">
      <h2 class="text-2xl font-bold">
        {getTranslation(locale, 'generator.stackPresets')}
      </h2>
      <span class="rounded-full bg-primary/10 px-3 py-0.5 text-xs font-semibold text-primary">
        {getTranslation(locale, 'generator.quickStart')}
      </span>
    </div>
    <p class="mt-2 text-gray-500">
      {getTranslation(locale, 'generator.stackPresetsDescription')}
    </p>

    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        stackPresetCards.map((preset) => (
          <a
            href={buildLocalizedPath(locale, `/generator/${preset.slug}`)}
            class="group flex flex-col rounded-xl border border-border bg-surface p-6 transition-all hover:border-primary hover:shadow-md"
          >
            <div class="text-3xl">{preset.icon}</div>
            <h3 class="mt-3 text-lg font-semibold text-gray-900 group-hover:text-primary">
              {preset.name}
            </h3>
            <p class="mt-1 text-sm text-gray-500">
              {preset.fileCount} {getTranslation(locale, 'generator.configFiles')}
            </p>
            <ul class="mt-4 flex flex-wrap gap-1.5">
              {preset.includedFiles.map((fileName) => (
                <li class="rounded bg-gray-100 px-2 py-0.5 font-mono text-xs text-gray-600">
                  {fileName}
                </li>
              ))}
            </ul>
          </a>
        ))
      }
    </div>
  </section>

  <!-- 구분선 -->
  <div class="mx-auto max-w-7xl px-6">
    <hr class="border-border" />
  </div>

  <!-- 개별 설정 파일 -->
  <section class="mx-auto max-w-7xl px-6 py-16">
    <h2 class="text-2xl font-bold">
      {getTranslation(locale, 'generator.individualFiles')}
    </h2>
    <p class="mt-2 text-gray-500">
      {getTranslation(locale, 'generator.individualFilesDescription')}
    </p>

    <!-- Common 카테고리 -->
    <div class="mt-10">
      <h3
        class="flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-gray-400"
      >
        <span class="h-px flex-1 bg-border"></span>
        <span>{getTranslation(locale, 'generator.categoryCommon')}</span>
        <span class="h-px flex-1 bg-border"></span>
      </h3>
      <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          commonFileCards.map((file) => (
            <a
              href={buildLocalizedPath(locale, `/generator/${file.slug}`)}
              class="group flex items-start gap-4 rounded-xl border border-border bg-surface p-5 transition-all hover:border-primary/50 hover:shadow-sm"
            >
              <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-gray-100 text-gray-400">
                <svg
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d={FILE_ICON_PATHS.document}
                  />
                </svg>
              </div>
              <div>
                <h4 class="font-mono text-sm font-semibold text-gray-900 group-hover:text-primary">
                  {file.name}
                </h4>
                <p class="mt-1 text-xs leading-relaxed text-gray-500">{getFileDescription(file)}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>

    <!-- Frontend / Node 카테고리 -->
    <div class="mt-12">
      <h3
        class="flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-gray-400"
      >
        <span class="h-px flex-1 bg-border"></span>
        <span>{getTranslation(locale, 'generator.categoryFrontend')}</span>
        <span class="h-px flex-1 bg-border"></span>
      </h3>
      <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          frontendFileCards.map((file) => (
            <a
              href={buildLocalizedPath(locale, `/generator/${file.slug}`)}
              class="group flex items-start gap-4 rounded-xl border border-border bg-surface p-5 transition-all hover:border-primary/50 hover:shadow-sm"
            >
              <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-gray-100 text-gray-400">
                <svg
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d={FILE_ICON_PATHS.code} />
                </svg>
              </div>
              <div>
                <h4 class="font-mono text-sm font-semibold text-gray-900 group-hover:text-primary">
                  {file.name}
                </h4>
                <p class="mt-1 text-xs leading-relaxed text-gray-500">{getFileDescription(file)}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
