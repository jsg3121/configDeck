---
import { buildLocalizedPath, getTranslation, SUPPORTED_LOCALES, type Locale } from '@/i18n'

import Layout from '@/layouts/Layout.astro'
import FileGenerator from '@/components/generator/FileGenerator.svelte'
import { FILE_DEFINITIONS, getRelatedFiles, type FileDefinition } from '@/lib/data/files'

export const getStaticPaths = () => {
  return SUPPORTED_LOCALES.flatMap((locale) =>
    FILE_DEFINITIONS.map((fileDef) => ({
      params: { locale, configFile: fileDef.slug },
    })),
  )
}

const { locale, configFile: fileSlug } = Astro.params as { locale: Locale; configFile: string }

const currentFile = FILE_DEFINITIONS.find((fileDef) => fileDef.slug === fileSlug) as FileDefinition

const pageTitle =
  locale === 'ko' ? `${currentFile.titleKo} — ConfigDeck` : `${currentFile.titleEn} — ConfigDeck`
const pageDescription = locale === 'ko' ? currentFile.descriptionKo : currentFile.descriptionEn

// JSON-LD 구조화 데이터
const siteUrl = 'https://configdeck.dev'

const softwareSourceCodeJsonLd = {
  '@type': 'SoftwareSourceCode',
  name: currentFile.fileName,
  description: pageDescription,
  programmingLanguage: {
    '@type': 'ComputerLanguage',
    name: currentFile.fileName.endsWith('.json')
      ? 'JSON'
      : currentFile.fileName.endsWith('.mjs') || currentFile.fileName.endsWith('.js')
        ? 'JavaScript'
        : currentFile.fileName.endsWith('.ts')
          ? 'TypeScript'
          : 'Configuration',
  },
  codeRepository: `${siteUrl}/${locale}/generator/${fileSlug}`,
}

const breadcrumbJsonLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: locale === 'ko' ? '홈' : 'Home',
      item: `${siteUrl}/${locale}`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: locale === 'ko' ? '생성기' : 'Generator',
      item: `${siteUrl}/${locale}/generator`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: currentFile.fileName,
    },
  ],
}

/**
 * 관련 파일 데이터를 Svelte에 전달 가능한 직렬화 형태로 변환한다.
 * 좌측 패널 하단 "함께 쓰면 좋아요" 섹션에서 카드로 렌더링한다.
 */
const relatedFiles = getRelatedFiles(fileSlug).map((file) => ({
  slug: file.slug,
  fileName: file.fileName,
  descriptionEn: file.descriptionEn,
  descriptionKo: file.descriptionKo,
  href: buildLocalizedPath(locale, `/generator/${file.slug}`),
}))
---

<Layout
  title={pageTitle}
  description={pageDescription}
  locale={locale}
  pagePath={`/generator/${fileSlug}`}
  currentPath={`/generator/${fileSlug}`}
  jsonLd={[softwareSourceCodeJsonLd, breadcrumbJsonLd]}
>
  <div class="w-full max-w-7xl mx-auto flex flex-col lg:h-[calc(100vh-65px)]">
    <!-- SEO: Astro 정적 영역 — 좌측 패널 폭에 맞춤 -->
    <div class="mx-auto w-full max-w-7xl shrink-0 px-6">
      <div class="w-full">
        <div class="mx-auto max-w-full pt-8">
          <a
            href={buildLocalizedPath(locale, '/generator')}
            class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
            </svg>
            {getTranslation(locale, 'common.backToGenerator')}
          </a>

          <div class="mt-6 mb-6">
            <h1 class="text-2xl font-bold tracking-tight">
              <span class="font-mono">{currentFile.fileName}</span>
            </h1>
            <p class="mt-2 text-sm text-gray-500">{pageDescription}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 인터랙티브: Svelte 아일랜드 — 나머지 높이를 채움 -->
    <div class="w-full min-h-0 flex-1">
      <FileGenerator
        client:load
        fileSlug={currentFile.slug}
        locale={locale}
        presets={[...currentFile.presets]}
        relatedFiles={relatedFiles}
      />
    </div>
  </div>
</Layout>
