---
import { buildLocalizedPath, getTranslation, SUPPORTED_LOCALES, type Locale } from '@/i18n'

import Layout from '@/layouts/Layout.astro'
import Header from '@/components/common/Header.astro'
import { STACK_DEFINITIONS, type StackDefinition } from '@/lib/data/stacks'

export const getStaticPaths = () => {
  return SUPPORTED_LOCALES.flatMap((locale) =>
    STACK_DEFINITIONS.map((stackDef) => ({
      params: { locale, stack: stackDef.slug },
    })),
  )
}

const { locale, stack: stackSlug } = Astro.params as { locale: Locale; stack: string }

const currentStack = STACK_DEFINITIONS.find(
  (stackDef) => stackDef.slug === stackSlug,
) as StackDefinition

const pageTitle =
  locale === 'ko'
    ? `${currentStack.name} 설정 생성기 — ConfigDeck`
    : `${currentStack.name} Generator — ConfigDeck`
const pageDescription = locale === 'ko' ? currentStack.descriptionKo : currentStack.descriptionEn

const fileNames = currentStack.includedFiles.map((includedFile) => includedFile.fileName)
const firstFileName = fileNames[0]

/**
 * sampleFiles 객체에서 첫 번째 파일의 샘플 코드를 가져온다.
 */
const getFirstSampleCode = (): string => {
  const sampleFilesRecord = currentStack.sampleFiles as Record<string, string>
  return sampleFilesRecord[firstFileName] ?? ''
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  locale={locale}
  pagePath={`/generator/${stackSlug}`}
  currentPath="/generator"
  bare
>
  <Header locale={locale} currentPath="/generator" />

  <!-- 2분할 레이아웃 -->
  <main class="flex flex-col lg:flex-row">
    <!-- 좌측 패널: 설정 -->
    <div class="w-full lg:h-[calc(100vh-65px)] lg:w-1/2 lg:overflow-y-auto">
      <div class="mx-auto max-w-xl px-6 py-8">
        <!-- 뒤로가기 링크 -->
        <a
          href={buildLocalizedPath(locale, '/generator')}
          class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900"
        >
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
          </svg>
          {getTranslation(locale, 'common.backToGenerator')}
        </a>

        <!-- 스택 타이틀 -->
        <div class="mt-6">
          <div class="flex items-center gap-3">
            <span class="text-3xl" role="img">{currentStack.icon}</span>
            <h1 class="text-2xl font-bold tracking-tight">{currentStack.name}</h1>
          </div>
          <p class="mt-2 text-sm text-gray-500">{pageDescription}</p>
        </div>

        <!-- 포함 파일 체크리스트 -->
        <fieldset class="mt-6 border-b border-border pb-6">
          <legend class="text-xs font-semibold uppercase tracking-wider text-gray-400">
            {getTranslation(locale, 'generator.includedFiles')}
          </legend>
          <div class="mt-3 flex flex-col gap-2.5">
            {
              currentStack.includedFiles.map((includedFile) => (
                <label class="flex cursor-pointer items-center gap-3">
                  <input
                    type="checkbox"
                    checked
                    class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                  />
                  <span class="font-mono text-sm text-gray-700">{includedFile.fileName}</span>
                </label>
              ))
            }
          </div>
        </fieldset>

        <!-- 파일별 옵션 아코디언 -->
        {
          currentStack.includedFiles.map((includedFile, fileIndex) => (
            <details
              open={fileIndex < 2}
              class:list={[
                'group py-5',
                fileIndex < currentStack.includedFiles.length - 1 && 'border-b border-border',
              ]}
            >
              <summary class="flex cursor-pointer select-none items-center justify-between">
                <span class="text-sm font-semibold text-gray-900">{includedFile.fileName}</span>
                <svg
                  class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="mt-4 flex flex-col gap-3 pl-1">
                {includedFile.options.map((option) => (
                  <label class="flex cursor-pointer items-center gap-3">
                    <input
                      type="checkbox"
                      checked={option.checked}
                      class="h-4 w-4 rounded border-gray-300 text-primary accent-primary"
                    />
                    <span class="text-sm text-gray-700">{option.label}</span>
                  </label>
                ))}
              </div>
            </details>
          ))
        }
      </div>
    </div>

    <!-- 우측 패널: 파일 탭 미리보기 -->
    <div
      class="w-full border-t border-border lg:sticky lg:top-0 lg:h-screen lg:w-1/2 lg:border-t-0 lg:border-l"
    >
      <div class="flex h-full flex-col bg-code-bg">
        <!-- 파일 탭 -->
        <div class="overflow-x-auto border-b border-gray-700">
          <div class="flex">
            {
              fileNames.map((fileName, tabIndex) => (
                <button
                  class:list={[
                    'shrink-0 border-b-2 px-4 py-2.5 font-mono text-xs font-medium transition-colors',
                    tabIndex === 0
                      ? 'border-primary bg-gray-800 text-white'
                      : 'border-transparent text-gray-500 hover:bg-gray-800/50 hover:text-gray-300',
                  ]}
                >
                  {fileName}
                </button>
              ))
            }
          </div>
        </div>

        <!-- 액션 바 -->
        <div class="flex items-center justify-end gap-2 border-b border-gray-700 px-5 py-2.5">
          <button
            class="inline-flex items-center gap-1.5 rounded-md border border-gray-600 px-3 py-1.5 text-xs font-medium text-gray-300 hover:bg-gray-700 hover:text-white"
          >
            <svg
              class="h-3.5 w-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
              ></path>
            </svg>
            {getTranslation(locale, 'common.copy')}
          </button>
          <button
            class="inline-flex items-center gap-1.5 rounded-md border border-gray-600 px-3 py-1.5 text-xs font-medium text-gray-300 hover:bg-gray-700 hover:text-white"
          >
            <svg
              class="h-3.5 w-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            {getTranslation(locale, 'common.download')}
          </button>
          <button
            class="inline-flex items-center gap-1.5 rounded-md bg-accent px-3.5 py-1.5 text-xs font-medium text-white hover:bg-accent/90"
          >
            <svg
              class="h-3.5 w-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            {getTranslation(locale, 'common.downloadAll')}
          </button>
        </div>

        <!-- 코드 미리보기 (첫 번째 파일) -->
        <div class="flex-1 overflow-auto p-5">
          <pre
            class="font-mono text-sm leading-relaxed text-gray-300"><code>{getFirstSampleCode()}</code></pre>
        </div>
      </div>
    </div>
  </main>
</Layout>
