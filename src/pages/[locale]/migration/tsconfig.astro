---
/**
 * TSConfig 진단 페이지.
 *
 * SPEC-0004 §3.2.2 — Phase C 10단계.
 * 결정 7에 따라 본 페이지는 상단/결과 양쪽에 권장값 안내 디스클레이머가 노출된다
 * (MigrationWorkbench 내부에서 toolType==='tsconfig' 일 때 자동 표시).
 */
import { buildLocalizedPath, getTranslation, SUPPORTED_LOCALES, type Locale } from '@/i18n'

import Layout from '@/layouts/Layout.astro'
import MigrationWorkbench from '@/components/migration/MigrationWorkbench.svelte'

export const getStaticPaths = () => {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }
---

<Layout
  title={getTranslation(locale, 'seo.migrationTsconfigTitle')}
  description={getTranslation(locale, 'seo.migrationTsconfigDescription')}
  locale={locale}
  pagePath="/migration/tsconfig"
  currentPath="/migration"
>
  <div class="mx-auto flex w-full max-w-7xl flex-col lg:h-[calc(100vh-65px)]">
    <div class="shrink-0 px-6 pt-8">
      <a
        href={buildLocalizedPath(locale, '/migration')}
        class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
        </svg>
        {getTranslation(locale, 'migration.hubTitle')}
      </a>

      <header class="mt-6 mb-6">
        <h1 class="text-3xl font-bold tracking-tight lg:text-4xl">
          {getTranslation(locale, 'migration.page.tsconfigTitle')}
        </h1>
        <p class="mt-3 max-w-3xl text-base text-gray-500">
          {getTranslation(locale, 'migration.page.tsconfigDescription')}
        </p>
      </header>
    </div>

    <div class="w-full min-h-0 flex-1">
      <MigrationWorkbench
        client:load
        locale={locale}
        toolType="tsconfig"
        outputFileName="tsconfig.json"
        placeholder={getTranslation(locale, 'migration.page.placeholders.tsconfig')}
        supportedFormatsLabel={getTranslation(locale, 'migration.page.supportedFormats.tsconfig')}
        acceptExtensions=".json,tsconfig.json,tsconfig.base.json"
      />
    </div>
  </div>
</Layout>
